---
import {
  CHART_GRID,
  getCurrentThemeColors,
  FIXED_COLORS,
  getStylePresets,
} from "../../config/themeConfig";

interface Props {
  competitiveAgentData: unknown[];
  competitiveRankData: unknown[];
  competitiveWeaponData: unknown[];
  competitiveMapData: unknown[];
  unratedAgentData: unknown[];
  unratedPerformanceData: unknown[];
  deathmatchPerformanceData: unknown[];
}

const {
  competitiveAgentData,
  competitiveRankData,
  competitiveWeaponData,
  competitiveMapData,
  unratedAgentData,
  unratedPerformanceData,
  deathmatchPerformanceData,
} = Astro.props;

const COLORS = { ...getCurrentThemeColors(), ...FIXED_COLORS };
const S = getStylePresets(COLORS);
---

<!-- JSONデータ埋め込み -->
<script type="application/json" id="competitive-agent-data" set:html={JSON.stringify(competitiveAgentData)}></script>
<script type="application/json" id="competitive-rank-data" set:html={JSON.stringify(competitiveRankData)}></script>
<script type="application/json" id="competitive-weapon-data" set:html={JSON.stringify(competitiveWeaponData)}></script>
<script type="application/json" id="competitive-map-data" set:html={JSON.stringify(competitiveMapData)}></script>
<script type="application/json" id="unrated-agent-data" set:html={JSON.stringify(unratedAgentData)}></script>
<script type="application/json" id="unrated-performance-data" set:html={JSON.stringify(unratedPerformanceData)}></script>
<script type="application/json" id="deathmatch-performance-data" set:html={JSON.stringify(deathmatchPerformanceData)}></script>

<!-- 統計データセクション -->
<div
  style={`background: ${COLORS.primaryAlpha10}; border: 2px solid ${COLORS.primary}; padding: 20px; margin-bottom: 40px; border-radius: 8px;`}
  class="stats-section"
  data-chart-color={CHART_GRID.themeColor}
  data-chart-grid-h={CHART_GRID.horizontal.color}
  data-chart-grid-h-width={String(CHART_GRID.horizontal.lineWidth)}
  data-chart-grid-v={CHART_GRID.vertical.color}
  data-chart-grid-v-width={String(CHART_GRID.vertical.lineWidth)}
  data-chart-kd-line-width={String(CHART_GRID.kdBaseline.lineWidth)}
  data-chart-tooltip={CHART_GRID.tooltipBg}
>
  <h2 style={`${S.sectionTitle} margin-bottom: 15px;`}>VALORANT Stats</h2>

  <hr style={`${S.divider} margin: 0 auto 20px auto; width: 100%;`} />

  <div class="mode-switcher">
    <button onclick="switchGameMode('competitive')" id="btn-mode-competitive" class="mode-btn active">COMPETITIVE</button>
    <button onclick="switchGameMode('unrated')" id="btn-mode-unrated" class="mode-btn">UNRATED</button>
    <button onclick="switchGameMode('swiftplay')" id="btn-mode-swiftplay" class="mode-btn">SWIFTPLAY</button>
    <button onclick="switchGameMode('spike_rush')" id="btn-mode-spike_rush" class="mode-btn">SPIKE RUSH</button>
    <button onclick="switchGameMode('deathmatch')" id="btn-mode-deathmatch" class="mode-btn">DEATHMATCH</button>
  </div>

  <div id="mode-unavailable" class="mode-unavailable" style="display: none;">
    <p class="mode-unavailable-text">DATA LOADING...</p>
    <p class="mode-unavailable-sub">選択されたモードのデータは現在準備中です</p>
  </div>

  <div class="charts-grid" id="charts-grid">
    <!-- RANK HISTORY -->
    <div class="chart-container">
      <div class="container">
        <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>RANK HISTORY</h3>
        <div class="chart-wrapper"><canvas id="rankChart"></canvas></div>
        <div class="controls">
          <button onclick="updateRankChart('rank')" id="btn-r-rank" class="active">Rank</button>
          <button onclick="updateRankChart('playtime')" id="btn-r-playtime">Playtime</button>
          <button onclick="updateRankChart('playtime_cumulative')" id="btn-r-playtime_cumulative">Cumulative</button>
          <button onclick="updateRankChart('wins')" id="btn-r-wins">Wins</button>
          <button onclick="updateRankChart('win_rate')" id="btn-r-win_rate">Win %</button>
          <button onclick="updateRankChart('kd')" id="btn-r-kd">K/D</button>
          <button onclick="updateRankChart('hs')" id="btn-r-hs">HS %</button>
        </div>
        <div class="footer-info">
          <span>SOURCE: <a href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/overview" target="_blank">TRACKER.GG / OVERVIEW</a></span>
          <span>LAST UPDATE: 2026/02/16</span>
        </div>
      </div>
    </div>

    <!-- MAP SCORE -->
    <div class="chart-container">
      <div class="container">
        <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>MAP SCORE</h3>
        <div class="chart-wrapper"><canvas id="mapChart"></canvas></div>
        <div class="controls">
          <button onclick="updateMapChart('win_rate')" id="btn-m-win_rate" class="active">Win %</button>
          <button onclick="updateMapChart('kd')" id="btn-m-kd">K/D</button>
          <button onclick="updateMapChart('adr')" id="btn-m-adr">ADR</button>
          <button onclick="updateMapChart('acs')" id="btn-m-acs">ACS</button>
        </div>
        <div class="footer-info">
          <span>SOURCE: <a href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/maps?platform=pc&playlist=competitive" target="_blank">TRACKER.GG / MAPS</a></span>
          <span>LAST UPDATE: 2026/02/16</span>
        </div>
      </div>
    </div>

    <!-- WEAPON SCORE -->
    <div class="chart-container">
      <div class="container">
        <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>WEAPON SCORE</h3>
        <div class="controls weapon-category-controls">
          <button onclick="toggleWeaponCategory('assault')" id="btn-wc-assault" class="active">Assault</button>
          <button onclick="toggleWeaponCategory('sniper')" id="btn-wc-sniper">Sniper</button>
          <button onclick="toggleWeaponCategory('smg')" id="btn-wc-smg">SMG</button>
          <button onclick="toggleWeaponCategory('shotgun')" id="btn-wc-shotgun">Shotgun</button>
          <button onclick="toggleWeaponCategory('sidearm')" id="btn-wc-sidearm">Sidearm</button>
          <button onclick="toggleWeaponCategory('lmg')" id="btn-wc-lmg">LMG</button>
          <button onclick="toggleWeaponCategory('other')" id="btn-wc-other">Other</button>
          <button onclick="toggleAllWeaponCategories()" id="btn-wc-all">All</button>
        </div>
        <div class="chart-wrapper"><canvas id="weaponChart"></canvas></div>
        <div class="controls">
          <button onclick="updateWeaponChart('kills')" id="btn-w-kills">Kills</button>
          <button onclick="updateWeaponChart('kd')" id="btn-w-kd" class="active">K/D</button>
          <button onclick="updateWeaponChart('hs_rate')" id="btn-w-hs_rate">HS %</button>
          <button onclick="updateWeaponChart('adr')" id="btn-w-adr">ADR</button>
          <button onclick="updateWeaponChart('kpr')" id="btn-w-kpr">K/R</button>
        </div>
        <div class="footer-info">
          <span>SOURCE: <a href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/weapons?platform=pc&playlist=competitive" target="_blank">TRACKER.GG / WEAPONS</a></span>
          <span>LAST UPDATE: 2026/02/16</span>
        </div>
      </div>
    </div>

    <!-- AGENT PERFORMANCE -->
    <div class="chart-container agent-chart-container">
      <div class="container agent-panel">
        <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>AGENT PERFORMANCE</h3>
        <div class="agent-role-filters">
          <button onclick="toggleAgentRole('Controller')" id="btn-role-controller" class="active">CONTROLLER</button>
          <button onclick="toggleAgentRole('Initiator')" id="btn-role-initiator" class="active">INITIATOR</button>
          <button onclick="toggleAgentRole('Duelist')" id="btn-role-duelist" class="active">DUELIST</button>
          <button onclick="toggleAgentRole('Sentinel')" id="btn-role-sentinel" class="active">SENTINEL</button>
        </div>
        <div class="chart-wrapper"><canvas id="agentChart"></canvas></div>
        <div class="controls agent-stat-controls">
          <button onclick="updateAgentStat('time')" id="btn-a-time" class="active">Time</button>
          <button onclick="updateAgentStat('matches')" id="btn-a-matches">Matches</button>
          <button onclick="updateAgentStat('win_rate')" id="btn-a-win_rate">Win%</button>
          <button onclick="updateAgentStat('kd')" id="btn-a-kd">K/D</button>
          <button onclick="updateAgentStat('adr')" id="btn-a-adr">ADR</button>
          <button onclick="updateAgentStat('acs')" id="btn-a-acs">ACS</button>
          <button onclick="updateAgentStat('hs')" id="btn-a-hs">HS%</button>
          <button onclick="updateAgentStat('kast')" id="btn-a-kast">KAST</button>
        </div>
        <div class="agent-filter-panel">
          <div class="agent-slider">
            <input
              type="range"
              id="agent-match-slider"
              min="0"
              max="300"
              step="10"
              value="20"
              oninput="updateAgentThreshold(this.value)"
            />
            <div class="agent-threshold-value" id="agent-threshold-display">MIN ≥ 20</div>
          </div>
        </div>
        <div class="footer-info agent-footer">
          <span>SOURCE: TRACKER.GG / AGENTS</span>
          <span>LAST UPDATE: 2026/02/19</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .mode-switcher {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }
  .mode-btn {
    background: transparent;
    color: #A6F7FF;
    border: 1px solid rgba(166, 247, 255, 0.25);
    padding: 6px 16px;
    font-family: var(--font-pixel-jp);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.15s ease;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .mode-btn:hover {
    background: rgba(166, 247, 255, 0.1);
    border-color: rgba(166, 247, 255, 0.5);
  }
  .mode-btn.active {
    background: rgba(77, 121, 255, 0.3);
    border: 2px solid #4d79ff;
    color: #ffffff;
    text-shadow: 0 0 10px rgba(77, 121, 255, 0.8);
    box-shadow: 0 0 12px rgba(77, 121, 255, 0.4), inset 0 0 8px rgba(77, 121, 255, 0.15);
  }
  .mode-unavailable {
    text-align: center;
    padding: 60px 20px;
    border: 2px dashed rgba(166, 247, 255, 0.3);
    border-radius: 8px;
    background: rgba(77, 121, 255, 0.05);
  }
  .mode-unavailable-text {
    font-family: var(--font-pixel);
    font-size: 18px;
    color: #A6F7FF;
    text-shadow: 0 0 10px rgba(166, 247, 255, 0.5);
    margin-bottom: 12px;
    animation: blink-loading 1.5s ease-in-out infinite;
  }
  .mode-unavailable-sub {
    font-family: var(--font-pixel-jp);
    font-size: 13px;
    color: rgba(166, 247, 255, 0.6);
  }
  @keyframes blink-loading {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .chart-container {
    background: var(--color-bg-secondary);
    border: 2px solid var(--theme-primary);
    padding: 20px;
    border-radius: 8px;
  }
  .chart-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1.7;
    max-height: 400px;
  }
  .controls {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    margin-bottom: 8px;
  }
  .controls button {
    background: transparent;
    color: #A6F7FF;
    border: 1px solid rgba(166, 247, 255, 0.3);
    padding: 4px 12px;
    font-family: var(--font-pixel-jp);
    font-size: 11px;
    cursor: pointer;
    transition: all 0.15s ease;
    border-radius: 2px;
  }
  .controls button:hover:not(:disabled) {
    background: rgba(166, 247, 255, 0.15);
    border-color: rgba(166, 247, 255, 0.6);
  }
  .controls button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: transparent;
    border-color: rgba(166, 247, 255, 0.2);
    color: rgba(166, 247, 255, 0.4);
    text-shadow: none;
    box-shadow: none;
  }
  .controls button.active {
    background: rgba(166, 247, 255, 0.25);
    border: 2px solid #A6F7FF;
    color: #ffffff;
    text-shadow: 0 0 8px rgba(166, 247, 255, 0.6);
    box-shadow: 0 0 8px rgba(166, 247, 255, 0.3), inset 0 0 6px rgba(166, 247, 255, 0.1);
  }
  .weapon-category-controls {
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .footer-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.75em;
    color: var(--theme-primary);
    opacity: 0.7;
    margin-top: 10px;
    padding-top: 8px;
  }
  .footer-info a {
    color: inherit;
    text-decoration: none;
  }
  .footer-info a:hover {
    text-decoration: underline;
  }
  .agent-chart-container {
    position: relative;
  }
  .agent-panel {
    position: relative;
  }
  .agent-filter-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin: 16px auto 0 auto;
    max-width: fit-content;
  }
  .agent-slider {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .agent-slider input[type="range"] {
    -webkit-appearance: none;
    width: 150px;
    background: transparent;
  }
  .agent-slider input[type="range"]:focus {
    outline: none;
  }
  .agent-slider input[type="range"]::-webkit-slider-runnable-track {
    height: 4px;
    background: rgba(166, 247, 255, 0.15);
    border: 1px solid rgba(166, 247, 255, 0.3);
  }
  .agent-slider input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    height: 16px;
    width: 10px;
    background: var(--theme-primary);
    border: 1px solid rgba(255,255,255,0.4);
    transform: translateY(-6px);
    box-shadow: 2px 2px 0 rgba(0,0,0,0.4);
  }
  .agent-threshold-value {
    font-size: 12px;
    color: #A6F7FF;
    font-family: var(--font-pixel-jp);
    min-width: 70px;
    text-align: right;
  }
  .agent-role-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }
  .agent-role-filters button {
    background: transparent;
    color: #A6F7FF;
    border: 1px solid rgba(166, 247, 255, 0.25);
    padding: 4px 12px;
    font-family: var(--font-pixel-jp);
    font-size: 11px;
    cursor: pointer;
    transition: all 0.15s ease;
    border-radius: 2px;
  }
  .agent-role-filters button.active {
    background: rgba(166, 247, 255, 0.25);
    border: 2px solid #A6F7FF;
    color: #ffffff;
    text-shadow: 0 0 8px rgba(166, 247, 255, 0.6);
    box-shadow: 0 0 8px rgba(166, 247, 255, 0.3), inset 0 0 6px rgba(166, 247, 255, 0.1);
  }
  .agent-role-filters button:hover {
    border-color: rgba(166, 247, 255, 0.6);
  }
  .agent-stat-controls {
    border-top: 1px solid rgba(166, 247, 255, 0.15);
    padding-top: 12px;
    margin-top: 16px;
  }
  .agent-footer {
    margin-top: 14px;
  }
  @media (max-width: 768px) {
    .charts-grid {
      grid-template-columns: 1fr;
    }
    .chart-container {
      padding: 12px;
      overflow: hidden;
    }
    .chart-wrapper {
      margin: 0 auto;
      max-width: 100%;
    }
    .footer-info {
      flex-direction: column;
      align-items: center;
      gap: 4px;
      text-align: center;
    }
    .agent-filter-panel {
      position: static;
      align-items: center;
      margin-bottom: 12px;
    }
    .agent-panel {
      padding-top: 0;
    }
  }
</style>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const statsEl = document.querySelector('.stats-section');
  const attr = (k, d) => statsEl?.getAttribute(k) || d;
  const THEME_COLOR = attr('data-chart-color', '#A6F7FF');
  const GRID_H = attr('data-chart-grid-h', 'hsla(185, 100%, 82%, 0.4)');
  const GRID_H_W = parseFloat(attr('data-chart-grid-h-width', '1'));
  const GRID_V = attr('data-chart-grid-v', 'hsla(185, 100%, 82%, 0.18)');
  const GRID_V_W = parseFloat(attr('data-chart-grid-v-width', '1'));
  const KD_LINE_W = parseFloat(attr('data-chart-kd-line-width', '2.5'));
  const TOOLTIP_BG = attr('data-chart-tooltip', 'rgba(5, 10, 20, 0.95)');

  const rankColors = { "Iron": "#718093", "Bronze": "#cd7f32", "Silver": "#dcdde1", "Gold": "#e1b12c", "Platinum": "#00a8ff", "Diamond": "#9c88ff", "Ascendant": "#44bd32", "Immortal": "#e84118", "Radiant": "#fbc531" };
  const allRanks = ["Iron 1", "Iron 2", "Iron 3", "Bronze 1", "Bronze 2", "Bronze 3", "Silver 1", "Silver 2", "Silver 3", "Gold 1", "Gold 2", "Gold 3", "Platinum 1", "Platinum 2", "Platinum 3", "Diamond 1", "Diamond 2", "Diamond 3", "Ascendant 1", "Ascendant 2", "Ascendant 3", "Immortal 1", "Immortal 2", "Immortal 3", "Radiant"];
  const getResponsiveRadius = (ctx) => ctx.chart.width < 500 ? 4 : 8;
  const kdScale = (values) => { const dev = Math.max(...values.map(v => Math.abs(v - 1.0)), 0.2); const step = dev <= 0.5 ? 0.2 : 0.5; const steps = Math.ceil(dev / step) + 1; return { min: Math.max(0, Math.round((1.0 - steps * step) * 10) / 10), max: Math.round((1.0 + steps * step) * 10) / 10, step }; };
  const wrScale = (values) => { const dev = Math.max(...values.map(v => Math.abs(v - 50)), 5); const step = dev <= 15 ? 5 : 10; const steps = Math.ceil(dev / step) + 1; return { min: Math.max(0, 50 - steps * step), max: Math.min(100, 50 + steps * step), step }; };

  // --- データ読み込み ---
  const gameData = {
    competitive: {
      agent: JSON.parse(document.getElementById('competitive-agent-data').textContent),
      rank:  JSON.parse(document.getElementById('competitive-rank-data').textContent),
      weapon: JSON.parse(document.getElementById('competitive-weapon-data').textContent),
      map:   JSON.parse(document.getElementById('competitive-map-data').textContent),
    },
    unrated: {
      agent: JSON.parse(document.getElementById('unrated-agent-data').textContent),
      rank:  JSON.parse(document.getElementById('unrated-performance-data').textContent),
    },
    deathmatch: {
      rank: JSON.parse(document.getElementById('deathmatch-performance-data').textContent),
    },
  };

  let rankData   = gameData.competitive.rank;
  let weaponData = gameData.competitive.weapon;
  let mapData    = gameData.competitive.map;
  let agentData  = gameData.competitive.agent;

  const allWeaponCats = ['assault', 'sniper', 'smg', 'shotgun', 'sidearm', 'lmg', 'other'];
  let activeWeaponCategories = new Set(['assault']);
  let currentWeaponMode = 'kd';
  let getFilteredWeapons = () => activeWeaponCategories.size === 0 ? weaponData : weaponData.filter(w => activeWeaponCategories.has(w.cat));
  let filteredWeapons = getFilteredWeapons();

  const agentColors = {
    "Astra": "#9d4edd", "Brimstone": "#d2691e", "Clove": "#c44569", "Harbor": "#20b2aa", "Omen": "#191970", "Viper": "#228b22",
    "Breach": "#ff8c00", "Fade": "#2f1b14", "Gekko": "#ffff00", "KAY/O": "#000080", "Skye": "#32cd32", "Sova": "#1e90ff", "Tejo": "#ffcc33",
    "Jett": "#87ceeb", "Neon": "#00ffff", "Phoenix": "#ff0000", "Raze": "#ff8c00", "Reyna": "#8b008b", "Yoru": "#191970",
    "Chamber": "#daa520", "Cypher": "#c9d6e8", "Deadlock": "#8b4513", "Killjoy": "#ffd700", "Sage": "#00ffff", "Vyse": "#6a0dad", "Iso": "#4a4a4a", "Waylay": "#ef476f"
  };
  const agentRoles = ["Controller", "Initiator", "Duelist", "Sentinel"];
  let agentThreshold = 20;
  let agentCurrentStat = 'time';
  let activeAgentRoles = new Set(agentRoles);

  Chart.defaults.font.family = "'DotGothic16', sans-serif";
  Chart.defaults.color = THEME_COLOR;

  const baselinePlugin = {
    id: 'baseline',
    afterDraw(chart) {
      const val = chart.config.options._baselineValue;
      if (val == null) return;
      const yScale = chart.scales.y;
      const y = yScale.getPixelForValue(val);
      if (y < yScale.top || y > yScale.bottom) return;
      const ctx = chart.ctx;
      ctx.save();
      ctx.beginPath();
      ctx.strokeStyle = GRID_H;
      ctx.lineWidth = KD_LINE_W;
      ctx.moveTo(chart.chartArea.left, y);
      ctx.lineTo(chart.chartArea.right, y);
      ctx.stroke();
      ctx.restore();
    },
  };
  Chart.register(baselinePlugin);

  const commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    scales: {
      y: { ticks: { color: THEME_COLOR }, grid: { color: GRID_H, lineWidth: GRID_H_W } },
      x: { ticks: { color: THEME_COLOR }, grid: { color: GRID_V, lineWidth: GRID_V_W } },
    },
    plugins: {
      legend: { display: false },
      tooltip: { backgroundColor: TOOLTIP_BG, borderColor: THEME_COLOR, borderWidth: 1, cornerRadius: 0 },
    },
  };

  const rankLabelFunc = (v) => {
    const i = Math.round(v);
    if (i >= 0 && i < allRanks.length) {
      const n = allRanks[i];
      if (n.endsWith("1") || n === "Radiant") return n;
    }
    return "";
  };

  // --- 1. RANK CHART ---
  const rChart = new Chart(document.getElementById('rankChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: rankData.map(d => d.act_id),
      datasets: [{
        data: rankData.map(d => allRanks.indexOf(d.rank)),
        borderColor: THEME_COLOR, borderWidth: 2,
        pointStyle: 'rect', pointRadius: getResponsiveRadius,
        pointBackgroundColor: rankData.map(d => rankColors[d.rank.split(' ')[0]] || THEME_COLOR),
        pointBorderColor: THEME_COLOR, pointBorderWidth: 1, tension: 0,
      }],
    },
    options: {
      ...commonOptions,
      scales: {
        y: {
          min: 0, max: 24,
          ticks: { stepSize: 1, callback: rankLabelFunc, autoSkip: false, maxRotation: 0, minRotation: 0 },
          grid: { color: (c) => c.tick.value % 3 === 0 ? GRID_H : GRID_H.replace('0.4)', '0.1)'), lineWidth: (c) => c.tick.value % 3 === 0 ? 2 : 1 },
        },
        x: { ...commonOptions.scales.x },
      },
      plugins: {
        ...commonOptions.plugins,
        tooltip: {
          ...commonOptions.plugins.tooltip,
          callbacks: {
            label: (item) => {
              const d = rankData[item.dataIndex];
              return [` RANK    : ${d.rank}`, ` PLAYTIME: ${d.playtime}h`, ` WINS    : ${d.wins}`, ` WIN %   : ${(d.win_rate * 100).toFixed(1)}%`, ` K/D     : ${d.kd.toFixed(2)}`, ` HS%     : ${(d.hs * 100).toFixed(1)}%`];
            },
          },
        },
      },
    },
  });

  // --- 2. WEAPON CHART ---
  const wChart = new Chart(document.getElementById('weaponChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: filteredWeapons.map(w => w.weapon),
      datasets: [{
        data: filteredWeapons.map(w => w.kd),
        borderColor: THEME_COLOR, borderWidth: 2,
        pointStyle: 'rect', pointRadius: getResponsiveRadius,
        pointBackgroundColor: THEME_COLOR, pointBorderColor: THEME_COLOR, pointBorderWidth: 1, tension: 0,
      }],
    },
    options: (() => {
      const s = kdScale(filteredWeapons.map(w => w.kd));
      return {
        ...commonOptions,
        _baselineValue: 1.0,
        scales: {
          x: { ticks: { color: THEME_COLOR, autoSkip: false, maxRotation: 45, minRotation: 45 }, grid: { color: GRID_V, lineWidth: GRID_V_W } },
          y: { min: s.min, max: s.max, ticks: { color: THEME_COLOR, stepSize: s.step, callback: v => v.toFixed(1) }, grid: { color: GRID_H, lineWidth: GRID_H_W } },
        },
        plugins: {
          ...commonOptions.plugins,
          tooltip: {
            ...commonOptions.plugins.tooltip,
            callbacks: {
              label: (item) => {
                const w = filteredWeapons[item.dataIndex];
                return [` KILLS   : ${w.kills}`, ` DEATHS  : ${w.deaths}`, ` K/D     : ${w.kd.toFixed(2)}`, ` HS %    : ${(w.hs_rate * 100).toFixed(1)}%`, ` ADR     : ${w.adr}`, ` K/ROUND : ${w.kpr}`];
              },
            },
          },
        },
      };
    })(),
  });

  // --- 3. MAP CHART ---
  const mChart = new Chart(document.getElementById('mapChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: mapData.map(m => m.map),
      datasets: [{
        data: mapData.map(m => (m.win_rate * 100).toFixed(1)),
        borderColor: THEME_COLOR, borderWidth: 2,
        pointStyle: 'rect', pointRadius: getResponsiveRadius,
        pointBackgroundColor: THEME_COLOR, pointBorderColor: THEME_COLOR, pointBorderWidth: 1, tension: 0,
      }],
    },
    options: (() => {
      const s = wrScale(mapData.map(m => m.win_rate * 100));
      return {
        ...commonOptions,
        _baselineValue: 50,
        scales: {
          y: { min: s.min, max: s.max, ticks: { stepSize: s.step, callback: v => v + '%' }, grid: { color: GRID_H, lineWidth: GRID_H_W } },
          x: { ticks: { color: THEME_COLOR }, grid: { color: GRID_V, lineWidth: GRID_V_W } },
        },
        plugins: {
          ...commonOptions.plugins,
          tooltip: {
            ...commonOptions.plugins.tooltip,
            callbacks: {
              label: (item) => {
                const m = mapData[item.dataIndex];
                return [` WIN %   : ${(m.win_rate * 100).toFixed(1)}%`, ` MATCHES : ${m.wins + m.losses}`, ` W / L   : ${m.wins} / ${m.losses}`, ` K/D     : ${m.kd.toFixed(2)}`, ` ADR     : ${m.adr}`, ` ACS     : ${m.acs}`];
              },
            },
          },
        },
      };
    })(),
  });

  // --- 4. AGENT CHART ---
  const agentThresholdDisplay = document.getElementById('agent-threshold-display');
  let getAgentFilteredData = () => agentData.filter(a => a.matches >= agentThreshold && activeAgentRoles.has(a.role));

  const agentChartEl = document.getElementById('agentChart');
  const agentChart = agentChartEl ? new Chart(agentChartEl.getContext('2d'), {
    type: 'line',
    data: {
      labels: [],
      datasets: [{
        data: [],
        borderColor: THEME_COLOR, borderWidth: 2,
        pointStyle: 'rect', pointRadius: getResponsiveRadius,
        pointBackgroundColor: [], pointBorderColor: THEME_COLOR, pointBorderWidth: 1, tension: 0,
      }],
    },
    options: {
      ...commonOptions,
      scales: {
        y: { ticks: { color: THEME_COLOR }, grid: { color: GRID_H, lineWidth: GRID_H_W } },
        x: { ticks: { color: THEME_COLOR, autoSkip: false, maxRotation: 45, minRotation: 45 }, grid: { color: GRID_V, lineWidth: GRID_V_W } },
      },
      plugins: {
        ...commonOptions.plugins,
        tooltip: {
          ...commonOptions.plugins.tooltip,
          callbacks: {
            label: (ctx) => {
              const agent = getAgentFilteredData()[ctx.dataIndex];
              if (!agent) return "";
              return [
                ` ROLE      : ${agent.role}`,
                ` TIME      : ${agent.time} hrs`,
                ` MATCHES   : ${agent.matches}`,
                ` WIN RATE  : ${agent.win_rate}%`,
                ` K/D RATIO : ${agent.kd.toFixed(2)}`,
                ` ADR       : ${agent.adr}`,
                ` ACS       : ${agent.acs}`,
                ` HS RATE   : ${agent.hs}%`,
                ` KAST      : ${agent.kast}%`,
              ];
            },
          },
        },
      },
    },
  }) : null;

  const syncAgentThresholdLabel = () => {
    if (agentThresholdDisplay) agentThresholdDisplay.textContent = `MATCHES ≥ ${agentThreshold}`;
  };

  const refreshAgentChart = () => {
    if (!agentChart) return;
    const filtered = getAgentFilteredData();
    agentChart.data.labels = filtered.map(a => a.name);
    agentChart.data.datasets[0].data = filtered.map(a => a[agentCurrentStat]);
    agentChart.data.datasets[0].pointBackgroundColor = filtered.map(a => agentColors[a.name] || THEME_COLOR);
    if (filtered.length === 0) {
      agentChart.options.scales.y.min = 0;
      agentChart.options.scales.y.max = 1;
      agentChart.options.scales.y.ticks.stepSize = 0.2;
      agentChart.options.scales.y.ticks.callback = v => v;
      agentChart.options._baselineValue = null;
      agentChart.update();
      return;
    }
    const isPct = ['win_rate', 'hs', 'kast'].includes(agentCurrentStat);
    if (isPct) {
      agentChart.options.scales.y.min = 0;
      agentChart.options.scales.y.max = 100;
      agentChart.options.scales.y.ticks.stepSize = 10;
      agentChart.options.scales.y.ticks.callback = v => `${v}%`;
    } else if (agentCurrentStat === 'kd') {
      const s = kdScale(filtered.map(a => a.kd));
      agentChart.options.scales.y.min = s.min;
      agentChart.options.scales.y.max = s.max;
      agentChart.options.scales.y.ticks.stepSize = s.step;
      agentChart.options.scales.y.ticks.callback = v => v.toFixed(1);
    } else {
      agentChart.options.scales.y.min = 0;
      agentChart.options.scales.y.max = undefined;
      agentChart.options.scales.y.ticks.stepSize = undefined;
      agentChart.options.scales.y.ticks.callback = v => v;
    }
    agentChart.options._baselineValue = agentCurrentStat === 'kd' ? 1.0 : null;
    agentChart.update();
  };

  window.updateAgentThreshold = function(val) {
    agentThreshold = parseInt(val, 10) || 0;
    syncAgentThresholdLabel();
    refreshAgentChart();
  };

  window.toggleAgentRole = function(role) {
    if (activeAgentRoles.has(role)) {
      activeAgentRoles.delete(role);
    } else {
      activeAgentRoles.add(role);
    }
    const btn = document.getElementById(`btn-role-${role.toLowerCase()}`);
    if (btn) btn.classList.toggle('active', activeAgentRoles.has(role));
    refreshAgentChart();
  };

  window.updateAgentStat = function(stat) {
    if (agentCurrentStat === stat) return;
    agentCurrentStat = stat;
    document.querySelectorAll('.agent-stat-controls button').forEach(btn => btn.classList.remove('active'));
    const activeBtn = document.getElementById(`btn-a-${stat}`);
    if (activeBtn) activeBtn.classList.add('active');
    refreshAgentChart();
  };

  syncAgentThresholdLabel();
  refreshAgentChart();

  // --- UPDATE FUNCTIONS ---
  window.updateRankChart = function(mode) {
    document.querySelectorAll('[id^="btn-r-"]').forEach(b => b.classList.remove('active'));
    document.getElementById(`btn-r-${mode}`).classList.add('active');
    const isRank = mode === 'rank';
    const isCumulative = mode === 'playtime_cumulative';
    rChart.data.labels = rankData.map(d => d.act_id);
    if (isCumulative) {
      let cumulative = 0;
      rChart.data.datasets[0].data = rankData.map(d => { cumulative += d.playtime; return Math.round(cumulative * 10) / 10; });
    } else {
      rChart.data.datasets[0].data = isRank
        ? rankData.map(d => allRanks.indexOf(d.rank))
        : mode === 'kd'
          ? rankData.map(d => d.kd)
          : rankData.map(d => d[mode === 'hs' ? 'hs' : mode] * (mode === 'playtime' || mode === 'wins' ? 1 : 100));
    }
    rChart.data.datasets[0].pointBackgroundColor = isRank
      ? rankData.map(d => rankColors[d.rank.split(' ')[0]] || THEME_COLOR)
      : THEME_COLOR;
    if (isRank) {
      rChart.options.scales.y.min = 0; rChart.options.scales.y.max = 24;
      rChart.options.scales.y.ticks.stepSize = 1; rChart.options.scales.y.ticks.callback = rankLabelFunc;
    } else if (mode === 'kd') {
      const s = kdScale(rankData.map(d => d.kd || 0));
      rChart.options.scales.y.min = s.min; rChart.options.scales.y.max = s.max;
      rChart.options.scales.y.ticks.stepSize = s.step; rChart.options.scales.y.ticks.callback = v => v.toFixed(1);
    } else if (mode === 'win_rate') {
      const s = wrScale(rankData.map(d => d.win_rate * 100));
      rChart.options.scales.y.min = s.min; rChart.options.scales.y.max = s.max;
      rChart.options.scales.y.ticks.stepSize = s.step; rChart.options.scales.y.ticks.callback = v => v + '%';
    } else if (mode === 'hs') {
      const s = wrScale(rankData.map(d => (d.hs || 0) * 100));
      rChart.options.scales.y.min = s.min; rChart.options.scales.y.max = s.max;
      rChart.options.scales.y.ticks.stepSize = s.step; rChart.options.scales.y.ticks.callback = v => v + '%';
    } else if (isCumulative) {
      rChart.options.scales.y.min = 0; rChart.options.scales.y.max = undefined;
      rChart.options.scales.y.ticks.stepSize = undefined; rChart.options.scales.y.ticks.callback = v => v + 'h';
    } else {
      rChart.options.scales.y.min = 0; rChart.options.scales.y.max = undefined;
      rChart.options.scales.y.ticks.stepSize = undefined; rChart.options.scales.y.ticks.callback = v => v;
    }
    rChart.options._baselineValue = mode === 'kd' ? 1.0 : mode === 'win_rate' ? 50 : null;
    rChart.update();
  };

  function refreshWeaponChart() {
    filteredWeapons = getFilteredWeapons();
    wChart.data.labels = filteredWeapons.map(w => w.weapon);
    const mode = currentWeaponMode;
    wChart.data.datasets[0].data = filteredWeapons.map(w => mode === 'hs_rate' ? (w.hs_rate * 100).toFixed(1) : w[mode]);
    if (mode === 'hs_rate') {
      const s = wrScale(filteredWeapons.map(m => m.hs_rate * 100));
      wChart.options.scales.y.min = s.min; wChart.options.scales.y.max = s.max;
      wChart.options.scales.y.ticks.stepSize = s.step; wChart.options.scales.y.ticks.callback = v => v + '%';
    } else if (mode === 'kd') {
      const s = kdScale(filteredWeapons.map(w => w.kd));
      wChart.options.scales.y.min = s.min; wChart.options.scales.y.max = s.max;
      wChart.options.scales.y.ticks.stepSize = s.step; wChart.options.scales.y.ticks.callback = v => v.toFixed(1);
    } else {
      wChart.options.scales.y.min = 0; wChart.options.scales.y.max = undefined;
      wChart.options.scales.y.ticks.stepSize = undefined; wChart.options.scales.y.ticks.callback = v => v;
    }
    wChart.options._baselineValue = mode === 'kd' ? 1.0 : null;
    wChart.update();
  }

  const syncWeaponCatButtons = () => {
    allWeaponCats.forEach(c => document.getElementById(`btn-wc-${c}`).classList.toggle('active', activeWeaponCategories.has(c)));
    document.getElementById('btn-wc-all').classList.toggle('active', activeWeaponCategories.size === allWeaponCats.length);
  };

  window.toggleWeaponCategory = function(cat) {
    if (activeWeaponCategories.has(cat)) { if (activeWeaponCategories.size > 1) activeWeaponCategories.delete(cat); }
    else activeWeaponCategories.add(cat);
    syncWeaponCatButtons();
    refreshWeaponChart();
  };

  window.toggleAllWeaponCategories = function() {
    activeWeaponCategories = activeWeaponCategories.size === allWeaponCats.length
      ? new Set(['assault'])
      : new Set(allWeaponCats);
    syncWeaponCatButtons();
    refreshWeaponChart();
  };

  window.updateWeaponChart = function(mode) {
    document.querySelectorAll('[id^="btn-w-"]').forEach(b => b.classList.remove('active'));
    document.getElementById(mode === 'kpr' ? 'btn-w-kpr' : `btn-w-${mode}`).classList.add('active');
    currentWeaponMode = mode;
    refreshWeaponChart();
  };

  window.updateMapChart = function(mode) {
    mChart.data.labels = mapData.map(m => m.map);
    document.querySelectorAll('[id^="btn-m-"]').forEach(b => b.classList.remove('active'));
    document.getElementById(`btn-m-${mode}`).classList.add('active');
    mChart.data.datasets[0].data = mapData.map(m => mode === 'win_rate' ? (m.win_rate * 100).toFixed(1) : m[mode]);
    if (mode === 'win_rate') {
      const s = wrScale(mapData.map(m => m.win_rate * 100));
      mChart.options.scales.y.min = s.min; mChart.options.scales.y.max = s.max;
      mChart.options.scales.y.ticks.stepSize = s.step; mChart.options.scales.y.ticks.callback = v => v + '%';
    } else if (mode === 'kd') {
      const s = kdScale(mapData.map(m => m.kd));
      mChart.options.scales.y.min = s.min; mChart.options.scales.y.max = s.max;
      mChart.options.scales.y.ticks.stepSize = s.step; mChart.options.scales.y.ticks.callback = v => v.toFixed(1);
    } else {
      mChart.options.scales.y.min = 0; mChart.options.scales.y.max = undefined;
      mChart.options.scales.y.ticks.stepSize = undefined; mChart.options.scales.y.ticks.callback = v => v;
    }
    mChart.options._baselineValue = mode === 'kd' ? 1.0 : mode === 'win_rate' ? 50 : null;
    mChart.update();
  };

  let currentGameMode = 'competitive';
  window.switchGameMode = function(mode) {
    if (mode === currentGameMode) return;
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
    document.getElementById(`btn-mode-${mode}`).classList.add('active');
    currentGameMode = mode;

    const modeData = gameData[mode];
    if (!modeData) {
      rankData = []; agentData = []; weaponData = []; mapData = [];
    } else {
      rankData   = modeData.rank   || [];
      agentData  = modeData.agent  || [];
      weaponData = modeData.weapon || [];
      mapData    = modeData.map    || [];
    }

    getFilteredWeapons  = () => activeWeaponCategories.size === 0 ? weaponData : weaponData.filter(w => activeWeaponCategories.has(w.cat));
    getAgentFilteredData = () => agentData.filter(a => a.matches >= agentThreshold && activeAgentRoles.has(a.role));

    const rankBtn = document.getElementById('btn-r-rank');
    const hsBtn   = document.getElementById('btn-r-hs');
    rankBtn.disabled = !(rankData.length > 0 && rankData[0].rank);
    if (rankBtn.disabled && rankBtn.classList.contains('active')) {
      document.getElementById('btn-r-playtime').click();
    }
    hsBtn.disabled = !(rankData.length > 0 && rankData[0].hs !== undefined);
    if (hsBtn.disabled && hsBtn.classList.contains('active')) {
      document.getElementById('btn-r-kd').click();
    }

    const activeRankMode = document.querySelector('[id^="btn-r-"].active').id.replace('btn-r-', '');
    updateRankChart(activeRankMode);
    const activeMapMode = document.querySelector('[id^="btn-m-"].active').id.replace('btn-m-', '');
    updateMapChart(activeMapMode);
    refreshWeaponChart();
    refreshAgentChart();
  };
});
</script>
