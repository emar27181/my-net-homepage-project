---
import SimpleLayout from "../layouts/SimpleLayout.astro";
import YouTubeClipViewer from "../components/YouTubeClipViewer.astro";
import { applyTypographyPreset } from "../utils/typography";
import {
  THEME_CONFIG,
  getCurrentThemeColors,
  FIXED_COLORS,
  FONT_SIZES,
  FONTS,
  CHART_GRID,
  getStylePresets,
} from "../config/themeConfig";
import "../styles/global.css";

// テーマカラー統合オブジェクト
const themeColors = getCurrentThemeColors();
const COLORS = { ...themeColors, ...FIXED_COLORS };

// スタイルプリセット（テンプレート内で S.title, S.bodyText 等で使用）
const S = getStylePresets(COLORS);
---

<link href="https://fonts.googleapis.com/css2?family=DotGothic16&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<SimpleLayout title="nodoame's Portfolio">
  <div
    style={`max-width: 1000px; margin: 0 auto; padding: 20px; background: var(--color-bg-secondary); border: 4px solid ${COLORS.primary}; border-radius: 12px; box-shadow: inset 2px 2px 0px ${COLORS.shadowWhite}, inset -2px -2px 0px ${COLORS.shadowBlack}, 0 0 20px ${COLORS.primaryShadow}; min-height: 100vh;`}
    class="main-container mobile-main"
  >
    <!-- タイトル -->
    <div style="text-align: center; margin-bottom: 40px;" class="title-section">
      <h1
        style={`color: ${COLORS.heading}; font-size: ${FONT_SIZES.title}; margin-bottom: 15px; font-family: ${FONTS.pixel}; image-rendering: pixelated; text-shadow: 1px 1px 0px ${COLORS.textBlack}; letter-spacing: 1px;`}
        class="main-title"
      >
        <span class="title-first-line">Nodoame's</span>
        <span class="title-second-line">Portfolio</span>
      </h1>

      <!-- 横線 -->
      <hr
        style={`${S.divider} margin: 0 auto 15px auto; width: 100%;`}
      />

      <!-- プロフィール画像 -->
      <img
        src="/icon_omencat_transparent.png"
        alt="nodoame profile"
        style={`width: 120px; height: 120px; margin: 0 auto 15px auto; display: block; border-radius: 8px; border: 2px solid ${COLORS.primary}; background-color: ${COLORS.primaryAlpha10}; padding: 5px;`}
      />

      <p
        style={`color: ${COLORS.textWhite}; font-size: ${FONT_SIZES.subtitle}; margin: 0;`}
        class={applyTypographyPreset("mainText")}
      >
        @nodoame27181 のポートフォリオ
      </p>
    </div>

    <!-- About Me -->
    <div
      style={`background: ${COLORS.primaryAlpha10}; border: 2px solid ${COLORS.primary}; padding: 20px; margin-bottom: 40px; border-radius: 8px;`}
      class="about-section"
    >
      <h2
        style={`${S.sectionTitle} margin-bottom: 15px;`}
      >
        About Me
      </h2>

      <!-- 横線 -->
      <hr
        style={`${S.divider} margin: 0 auto 20px auto; width: 100%;`}
      />

      <div style="text-align: center; margin-bottom: 15px;">
                  <p
                    style={`${S.bodyText}`}
                  >
                    VALORANTをメインにプレイしている猫好きなゲーマー、nodoame (のどあめん / nodoamen) です。<br />
                    <br />
                    ゲーム以外にもWeb制作やプログラミングに興味があり、<br />
                    このポートフォリオサイトを制作しました。<br />
                    最近はVALORANTの戦略研究やマップ分析にも力を入れています。<br />
                    <br />
                    ※このサイトはClaude Codeを用いて作られました。
                  </p>      </div>
    </div>

    <!-- プロフィール情報 -->
    <div
      style={`background: ${COLORS.primaryAlpha10}; border: 2px solid ${COLORS.primary}; padding: 20px; margin-bottom: 40px; border-radius: 8px;`}
      class="profile-section"
    >
      <h2
        style={`${S.sectionTitle} margin-bottom: 15px;`}
      >
        Player Info
      </h2>

      <!-- 横線 -->
      <hr
        style={`${S.divider} margin: 0 auto 20px auto; width: 100%;`}
      />

      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;"
        class="profile-info-grid"
      >
        <div>
          <h3
            style={`${S.subTitle} margin-bottom: 10px;`}
          >
            基本情報
          </h3>
          <p
            style={`${S.bodyText}`}
          >
            名前: nodoame<br />
            メインロール: コントローラー(オーメン/クローブ/アストラ) <br />
          </p>

          <h3
            style={`${S.subTitle} margin-bottom: 10px; margin-top: 15px;`}
          >
            プレイ中のゲーム
          </h3>
          <p
            style={`${S.bodyText}`}
          >
            FPS: Valorant / Apex / OW2 / BF / COD / Fortnite(昔)<br />
            ソシャゲ: パズドラ / モンスト / ポケポケ / 雀魂
          </p>
        </div>

        <div>
          <h3
            style={`${S.subTitle} margin-bottom: 10px;`}
          >
            外部リンク
          </h3>
          <p
            style={`${S.bodyText}`}
          >
            <svg
              style="display: inline-block; width: 16px; height: 16px; vertical-align: middle; margin-right: 5px;"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>Twitter: <a
              href="https://twitter.com/nodoame27181"
              target="_blank"
              rel="noopener"
              style={S.link}>@nodoame27181</a
            ><br />
            <svg
              style="display: inline-block; width: 16px; height: 16px; vertical-align: middle; margin-right: 5px;"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>Youtube: <a
              href="https://www.youtube.com/@nodoame27181"
              target="_blank"
              rel="noopener"
              style={S.link}>@nodoame27181</a
            ><br />
            <svg
              style="display: inline-block; width: 16px; height: 16px; vertical-align: middle; margin-right: 5px;"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M3 3v18h18V3H3zm16 16H5V5h14v14zM7 10h2v7H7v-7zm4-3h2v10h-2V7zm4 6h2v4h-2v-4z"
              ></path>
            </svg>TRN:<br />
            <span style="margin-left: 24px;"
              >Valorant: <a
                href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/overview?platform=pc&playlist=competitive&season=4c4b8cff-43eb-13d3-8f14-96b783c90cd2"
                target="_blank"
                rel="noopener"
                style={S.link}>Valorant Profile</a
              ></span
            ><br />
            <span style="margin-left: 24px;"
              >Valorant(Solo): <a
                href="https://tracker.gg/valorant/profile/riot/nodoame%2327182/overview?platform=pc&playlist=competitive&season=4c4b8cff-43eb-13d3-8f14-96b783c90cd2"
                target="_blank"
                rel="noopener"
                style={S.link}>Valorant Profile (Solo)</a
              ></span
            ><br />
            <span style="margin-left: 24px;"
              >Fortnite: <a
                href="https://fortnitetracker.com/profile/kbm/nodoamen/events?region=GLOBAL&sortBy=placement"
                target="_blank"
                rel="noopener"
                style={S.link}>Fortnite Profile</a
              ></span
            ><br />
            <span style="margin-left: 24px;"
              >Apex: <a
                href="https://apex.tracker.gg/apex/profile/origin/nodoamen/performance"
                target="_blank"
                rel="noopener"
                style={S.link}>Apex Profile</a
              ></span
            ><br />
          </p>
        </div>
      </div>
    </div>

    <!-- 統計データセクション -->
    <div
      style={`background: ${COLORS.primaryAlpha10}; border: 2px solid ${COLORS.primary}; padding: 20px; margin-bottom: 40px; border-radius: 8px;`}
      class="stats-section"
      data-chart-color={CHART_GRID.themeColor}
      data-chart-grid-h={CHART_GRID.horizontal.color}
      data-chart-grid-h-width={String(CHART_GRID.horizontal.lineWidth)}
      data-chart-grid-v={CHART_GRID.vertical.color}
      data-chart-grid-v-width={String(CHART_GRID.vertical.lineWidth)}
      data-chart-kd-line-width={String(CHART_GRID.kdBaseline.lineWidth)}
      data-chart-tooltip={CHART_GRID.tooltipBg}
    >
      <h2
        style={`${S.sectionTitle} margin-bottom: 15px;`}
      >
        VALORANT Stats
      </h2>

      <hr
        style={`${S.divider} margin: 0 auto 20px auto; width: 100%;`}
      />

      <div class="mode-switcher">
        <button onclick="switchGameMode('competitive')" id="btn-mode-competitive" class="mode-btn active">COMPETITIVE</button>
        <button onclick="switchGameMode('unrated')" id="btn-mode-unrated" class="mode-btn">UNRATED</button>
        <button onclick="switchGameMode('swiftplay')" id="btn-mode-swiftplay" class="mode-btn">SWIFTPLAY</button>
        <button onclick="switchGameMode('spike_rush')" id="btn-mode-spike_rush" class="mode-btn">SPIKE RUSH</button>
        <button onclick="switchGameMode('deathmatch')" id="btn-mode-deathmatch" class="mode-btn">DEATHMATCH</button>
      </div>

      <div id="mode-unavailable" class="mode-unavailable" style="display: none;">
        <p class="mode-unavailable-text">DATA LOADING...</p>
        <p class="mode-unavailable-sub">選択されたモードのデータは現在準備中です</p>
      </div>

      <div class="charts-grid" id="charts-grid">
        <div class="chart-container">
          <div class="container">
            <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>RANK HISTORY</h3>
            <div class="chart-wrapper"><canvas id="rankChart"></canvas></div>
            <div class="controls">
              <button onclick="updateRankChart('rank')" id="btn-r-rank" class="active">Rank</button>
              <button onclick="updateRankChart('playtime')" id="btn-r-playtime">Playtime</button>
              <button onclick="updateRankChart('playtime_cumulative')" id="btn-r-playtime_cumulative">Cumulative</button>
              <button onclick="updateRankChart('wins')" id="btn-r-wins">Wins</button>
              <button onclick="updateRankChart('win_rate')" id="btn-r-win_rate">Win %</button>
              <button onclick="updateRankChart('kd')" id="btn-r-kd">K/D</button>
              <button onclick="updateRankChart('hs')" id="btn-r-hs">HS %</button>
            </div>
            <div class="footer-info"><span>SOURCE: <a href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/overview" target="_blank">TRACKER.GG / OVERVIEW</a></span><span>LAST UPDATE: 2026/02/16</span></div>
          </div>
        </div>
        <div class="chart-container">
          <div class="container">
            <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>MAP SCORE</h3>
            <div class="chart-wrapper"><canvas id="mapChart"></canvas></div>
            <div class="controls">
              <button onclick="updateMapChart('win_rate')" id="btn-m-win_rate" class="active">Win %</button>
              <button onclick="updateMapChart('kd')" id="btn-m-kd">K/D</button>
              <button onclick="updateMapChart('adr')" id="btn-m-adr">ADR</button>
              <button onclick="updateMapChart('acs')" id="btn-m-acs">ACS</button>
            </div>
            <div class="footer-info"><span>SOURCE: <a href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/maps?platform=pc&playlist=competitive" target="_blank">TRACKER.GG / MAPS</a></span><span>LAST UPDATE: 2026/02/16</span></div>
          </div>
        </div>
        <div class="chart-container">
          <div class="container">
            <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>WEAPON SCORE</h3>
            <div class="controls weapon-category-controls">
              <button onclick="toggleWeaponCategory('assault')" id="btn-wc-assault" class="active">Assault</button>
              <button onclick="toggleWeaponCategory('sniper')" id="btn-wc-sniper">Sniper</button>
              <button onclick="toggleWeaponCategory('smg')" id="btn-wc-smg">SMG</button>
              <button onclick="toggleWeaponCategory('shotgun')" id="btn-wc-shotgun">Shotgun</button>
              <button onclick="toggleWeaponCategory('sidearm')" id="btn-wc-sidearm">Sidearm</button>
              <button onclick="toggleWeaponCategory('lmg')" id="btn-wc-lmg">LMG</button>
              <button onclick="toggleWeaponCategory('other')" id="btn-wc-other">Other</button>
              <button onclick="toggleAllWeaponCategories()" id="btn-wc-all">All</button>
            </div>
            <div class="chart-wrapper"><canvas id="weaponChart"></canvas></div>
            <div class="controls">
              <button onclick="updateWeaponChart('kills')" id="btn-w-kills">Kills</button>
              <button onclick="updateWeaponChart('kd')" id="btn-w-kd" class="active">K/D</button>
              <button onclick="updateWeaponChart('hs_rate')" id="btn-w-hs_rate">HS %</button>
              <button onclick="updateWeaponChart('adr')" id="btn-w-adr">ADR</button>
              <button onclick="updateWeaponChart('kpr')" id="btn-w-kpr">K/R</button>
            </div>
            <div class="footer-info"><span>SOURCE: <a href="https://tracker.gg/valorant/profile/riot/nodoame%2327181/weapons?platform=pc&playlist=competitive" target="_blank">TRACKER.GG / WEAPONS</a></span><span>LAST UPDATE: 2026/02/16</span></div>
          </div>
        </div>
        <div class="chart-container agent-chart-container">
          <div class="container agent-panel">
            <h3 style={`${S.subTitle} margin-bottom: 10px; text-align: center;`}>AGENT PERFORMANCE</h3>
            <div class="agent-role-filters">
              <button onclick="toggleAgentRole('Controller')" id="btn-role-controller" class="active">CONTROLLER</button>
              <button onclick="toggleAgentRole('Initiator')" id="btn-role-initiator" class="active">INITIATOR</button>
              <button onclick="toggleAgentRole('Duelist')" id="btn-role-duelist" class="active">DUELIST</button>
              <button onclick="toggleAgentRole('Sentinel')" id="btn-role-sentinel" class="active">SENTINEL</button>
            </div>
            <div class="chart-wrapper"><canvas id="agentChart"></canvas></div>
            <div class="controls agent-stat-controls">
              <button onclick="updateAgentStat('time')" id="btn-a-time" class="active">Time</button>
              <button onclick="updateAgentStat('matches')" id="btn-a-matches">Matches</button>
              <button onclick="updateAgentStat('win_rate')" id="btn-a-win_rate">Win%</button>
              <button onclick="updateAgentStat('kd')" id="btn-a-kd">K/D</button>
              <button onclick="updateAgentStat('adr')" id="btn-a-adr">ADR</button>
              <button onclick="updateAgentStat('acs')" id="btn-a-acs">ACS</button>
              <button onclick="updateAgentStat('hs')" id="btn-a-hs">HS%</button>
              <button onclick="updateAgentStat('kast')" id="btn-a-kast">KAST</button>
            </div>
            <div class="agent-filter-panel">

              <div class="agent-slider">
                <input
                  type="range"
                  id="agent-match-slider"
                  min="0"
                  max="300"
                  step="10"
                  value="20"
                  oninput="updateAgentThreshold(this.value)"
                />
                <div class="agent-threshold-value" id="agent-threshold-display">MIN ≥ 20</div>
              </div>
            </div>
            <div class="footer-info agent-footer"><span>SOURCE: TRACKER.GG / AGENTS</span><span>LAST UPDATE: 2026/02/19</span></div>
          </div>
        </div>
      </div>
    </div>


        <!-- YouTube動画セクション -->


        <div


          style={`background: ${COLORS.primaryAlpha10}; border: 2px solid ${COLORS.primary}; padding: 20px; margin-bottom: 40px; border-radius: 8px;`}


          class="video-section"


        >


          <h2


            style={`${S.sectionTitle} margin-bottom: 15px;`}


          >


            VALORANT Gameplay


          </h2>


    


          <!-- 横線 -->


          <hr


            style={`${S.divider} margin: 0 auto 20px auto; width: 100%;`}


          />


    


          <!-- カルーセル表示（折りたたみ時） -->


          <div id="video-carousel" style="position: relative;">


            <!-- 動画表示エリア -->


            <div class="video-container" style="position: relative;">


              <div class="carousel-video" data-index="0">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/eAx-dZ3_wEI?si=LM3jptJTQAkeco-o"


                  title="VALORANT Clip #1"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="1" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/KTwFA1jQgFY"


                  title="VALORANT Clip #2"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="2" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/oos2PYWiRGM"


                  title="VALORANT Clip #3"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="3" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://www.youtube.com/watch?v=5IET-4mL9pA"


                  title="VALORANT Clip #4"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="4" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/46a0f7dNVW4?si=FjCr_YPa35-guCZX"


                  title="VALORANT Clip #5"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="5" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/Yznxiz_tS4g?si=sWJFRV_vB95mkJNl"


                  title="VALORANT Clip #6"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="6" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/ooJdHWZ3KyU?si=pS2rqHsxPnuRqmEV"


                  title="VALORANT Clip #7"


                  autoplay={false}


                />


              </div>


              <div class="carousel-video" data-index="7" style="display: none;">


                <YouTubeClipViewer


                  clipUrl="https://youtu.be/Aazj-kAuxdY"


                  title="VALORANT Clip #8"


                  autoplay={false}


                />


              </div>


            </div>


    


            <!-- 左矢印ボタン -->


            <button


              id="prev-video-btn"


              style={`position: absolute; top: 50%; left: 10px; transform: translateY(-50%); z-index: 10; width: 40px; height: 40px; background: rgba(77, 121, 255, 0.2); color: ${COLORS.textWhite}; border: 1px solid rgba(77, 121, 255, 0.5); border-radius: 4px; font-size: 20px; font-family: ${FONTS.pixelJp}; cursor: pointer; image-rendering: pixelated; text-shadow: 1px 1px 0px ${COLORS.textBlack}; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center;`}


              onmouseover={`this.style.background='${COLORS.bgTransparent}'; this.style.color='${COLORS.primary}'; this.style.border='2px solid ${COLORS.primary}';`}


              onmouseout={`this.style.background='rgba(77, 121, 255, 0.2)'; this.style.color='${COLORS.textWhite}'; this.style.border='1px solid rgba(77, 121, 255, 0.5)';`}


            >


              ◀


            </button>


    


            <!-- 右矢印ボタン -->


            <button


              id="next-video-btn"


              style={`position: absolute; top: 50%; right: 10px; transform: translateY(-50%); z-index: 10; width: 40px; height: 40px; background: rgba(77, 121, 255, 0.2); color: ${COLORS.textWhite}; border: 1px solid rgba(77, 121, 255, 0.5); border-radius: 4px; font-size: 20px; font-family: ${FONTS.pixelJp}; cursor: pointer; image-rendering: pixelated; text-shadow: 1px 1px 0px ${COLORS.textBlack}; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center;`}


              onmouseover={`this.style.background='${COLORS.bgTransparent}'; this.style.color='${COLORS.primary}'; this.style.border='2px solid ${COLORS.primary}';`}


              onmouseout={`this.style.background='rgba(77, 121, 255, 0.2)'; this.style.color='${COLORS.textWhite}'; this.style.border='1px solid rgba(77, 121, 255, 0.5)';`}


            >


              ▶


            </button>


            <!-- 現在位置インジケーター -->


            <div style="text-align: center; margin-top: 15px;">


              <p


                id="video-counter"


                style={`${S.bodyTextCompact}`}


              >


                1 / 8


              </p>


            </div>


          </div>


        </div>

    <!-- デバイス情報 -->
    <div
      style={`background: ${COLORS.primaryAlpha10}; border: 2px solid ${COLORS.primary}; padding: 20px; margin-bottom: 40px; border-radius: 8px;`}
      class="device-section"
    >
      <h2
        style={`${S.sectionTitle} margin-bottom: 15px;`}
      >
        Valorant Setup
      </h2>

      <!-- 横線 -->
      <hr
        style={`${S.divider} margin: 0 auto 20px auto; width: 100%;`}
      />

      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;"
        class="device-settings-grid"
      >
        <div>
          <h3
            style={`${S.subTitle} margin-bottom: 10px;`}
          >
            デバイス
          </h3>
          <p
            style={`${S.bodyText}`}
          >
            マウス: <a href="https://www.amazon.co.jp/dp/B0FVKKP2T8?ref=ppx_yo2ov_dt_b_fed_asin_title&th=1" target="_blank" style={S.link}>Pulsar Gaming Gears X2 CrazyLight</a><br />
            キーボード: <a href="https://www.amazon.co.jp/dp/B0DCFGG1CH?ref_=ppx_hzsearch_conn_dt_b_fed_asin_title_1&th=1" target="_blank" style={S.link}>Akko 5075S HE JP (Black)</a><br />
            ヘッドセット: <a href="https://www.amazon.co.jp/dp/B0BFFDNH1J?ref_=ppx_hzsearch_conn_dt_b_fed_asin_title_1&th=1" target="_blank" style={S.link}>Razer BlackShark V2 Pro</a><br />
