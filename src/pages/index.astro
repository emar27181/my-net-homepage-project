    background: #4d79ff;
    border-color: #88aaff;
    color: #000000;
    text-shadow: none;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3), 0 2px 0 #1a3a99, 0 0 8px rgba(77,121,255,0.5);
  }

  .console-tiny-label {
    font-family: var(--font-pixel);
    font-size: 6px;
    color: #333355;
    text-shadow: 1px 1px 0 #000;
    letter-spacing: 1px;
    image-rendering: pixelated;
    white-space: nowrap;
  }

  /* ===== フィルター効果 CSS ===== */

  /* ===== CRT フィルター（強化版） ===== */

  /* フレーム全体: フリッカー + 強グロー */
  #viewer-frame.filter-crt {
    border-color: #1a3366;
    box-shadow:
      inset 4px 4px 0 rgba(255,255,255,0.06),
      inset -4px -4px 0 rgba(0,0,0,0.9),
      0 0 0 3px #050510,
      0 0 30px rgba(100,160,255,0.7),
      0 0 70px rgba(60,100,220,0.4),
      0 0 120px rgba(30,60,180,0.2);
    animation: crt-flicker 6s linear infinite;
    filter: brightness(0.95) contrast(1.15);
  }

  /* 画像: フォスファー発光っぽい色合い */
  #viewer-frame.filter-crt .illust-img {
    filter: contrast(1.5) brightness(0.78) saturate(1.4) hue-rotate(-8deg) sepia(0.12);
    transition: filter 0.3s ease;
  }

  /* スキャンライン: 強め2段階 */
  #viewer-frame.filter-crt .illust-scanlines {
    opacity: 1 !important;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(0, 0, 0, 0) 0px,
        rgba(0, 0, 0, 0) 1px,
        rgba(0, 0, 0, 0.5) 1px,
        rgba(0, 0, 0, 0.5) 2px,
        rgba(0, 10, 30, 0.1) 2px,
        rgba(0, 10, 30, 0.1) 4px
      ) !important;
    z-index: 5 !important;
  }

  /* CRT vignette 強化: 深いすり鉢形 */
  #viewer-frame.filter-crt::after {
    background:
      radial-gradient(
        ellipse at 50% 50%,
        transparent 38%,
        rgba(0, 0, 20, 0.4) 65%,
        rgba(0, 0, 30, 0.85) 100%
      ) !important;
    z-index: 6;
  }

  /* CRT 走査線ロールオーバーレイ */
  #viewer-frame.filter-crt::before {
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 1px,
        rgba(0, 0, 0, 0.22) 1px,
        rgba(0, 0, 0, 0.22) 2px
      ),
      linear-gradient(
        180deg,
        rgba(100, 150, 255, 0.03) 0%,
        transparent 50%,
        rgba(0, 0, 50, 0.05) 100%
      ) !important;
    animation: crt-scanroll 8s linear infinite !important;
  }

  /* Game Boy: グレースケール + 緑ティント + 高コントラスト */
  #viewer-frame.filter-gb .illust-img {
    filter: grayscale(1) contrast(2.8) brightness(0.65);
    transition: filter 0.3s ease;
  }

  /* 緑ティントオーバーレイ */
  #viewer-frame.filter-gb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(15, 56, 15, 0.42);
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 3;
  }

  /* GB ドットグリッドオーバーレイ */
  #viewer-frame.filter-gb .illust-scanlines {
    opacity: 1 !important;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0,20,0,0.22) 3px,
      rgba(0,20,0,0.22) 4px
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 3px,
      rgba(0,20,0,0.12) 3px,
      rgba(0,20,0,0.12) 4px
    ) !important;
  }

  /* VHS: RGBずれ(SVGフィルター) + 色彩強め + トラッキングノイズ */
  @keyframes vhs-tracking {
    0%   { transform: translateX(0) skewX(0deg); }
    94%  { transform: translateX(0) skewX(0deg); }
    95%  { transform: translateX(-4px) skewX(-0.4deg); filter: url(#svg-vhs-filter) saturate(2.8) contrast(1.3) brightness(0.82) hue-rotate(8deg) blur(0.3px); }
    96%  { transform: translateX(3px) skewX(0.3deg); }
    97%  { transform: translateX(0) skewX(0deg); }
    100% { transform: translateX(0) skewX(0deg); }
  }

  #viewer-frame.filter-vhs .illust-img {
    filter: url(#svg-vhs-filter) saturate(2.6) contrast(1.25) brightness(0.85) hue-rotate(5deg);
    animation: vhs-tracking 4s step-end infinite;
    transition: filter 0.3s ease;
  }

  /* VHS ノイズライン */
  #viewer-frame.filter-vhs .illust-scanlines {
    opacity: 1 !important;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 4px,
      rgba(255, 80, 80, 0.05) 4px,
      rgba(255, 80, 80, 0.05) 5px
    ) !important;
  }

  /* スクリーン表示色（フィルター別） */
  .console-screen-main.mode-crt {
    color: #ff8844;
    text-shadow: 0 0 8px rgba(255,100,0,0.7), 0 0 16px rgba(200,60,0,0.4), 1px 1px 0 #000;
  }

  .console-screen-main.mode-gb {
    color: #44ff66;
    text-shadow: 0 0 8px rgba(0,255,80,0.7), 0 0 16px rgba(0,200,60,0.4), 1px 1px 0 #000;
  }

  .console-screen-main.mode-vhs {
    color: #ff44cc;
    text-shadow: 0 0 8px rgba(255,0,180,0.7), 0 0 16px rgba(200,0,140,0.4), 1px 1px 0 #000;
  }

  @media (max-width: 600px) {
    .retro-console {
      flex-direction: column;
      gap: 10px;
      padding: 12px;
    }
    .console-center {
      width: 100%;
    }
    .filter-chip-group {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  function copyCrosshairCode() {
    navigator.clipboard.writeText(
      "0;p;0;s;1;P;c;8;u;0077FFFF;o;0.3;b;1;f;0;0t;1;0l;5;0v;5;0o;2;0a;1;0f;0;1t;3;1o;2;1a;1;1m;0;1f;0;A;c;5;u;0077FFFF;o;0.2;0t;3;0l;1;0v;1;0o;1;0a;1;0f;0;1b;0;S;c;5",
    );

    // アイコンとテキストを切り替え
    const copyIcon = document.getElementById("copy-crosshair-icon");
    const checkIcon = document.getElementById("check-crosshair-icon");
    const label = document.getElementById("copy-crosshair-label");

    if (copyIcon && checkIcon && label) {
      copyIcon.style.display = "none";
      checkIcon.style.display = "inline-block";
      label.textContent = "コピーしました！";

      // 2秒後に元に戻す
      setTimeout(() => {
        checkIcon.style.display = "none";
        copyIcon.style.display = "inline-block";
        label.textContent = "クロスヘアコードをコピー";
      }, 2000);
    }
  }

  let currentVideoIndex = 0;
  const totalVideos = 8;
  let videoSources = []; // 各動画のオリジナルsrcを保存

  function initializeVideoSources() {
    const videos = document.querySelectorAll(".carousel-video");
    videos.forEach((video, i) => {
      const iframe = video.querySelector("iframe");
      if (iframe && iframe.src) {
        videoSources[i] = iframe.src;
      }
    });
  }

  function showVideo(index) {
    const videos = document.querySelectorAll(".carousel-video");
    const counter = document.getElementById("video-counter");

    videos.forEach((video, i) => {
      if (i === index) {
        video.style.display = "block";
        // 表示する動画のsrcを復元（黒画面を防ぐ）
        const iframe = video.querySelector("iframe");
        if (iframe && videoSources[i] && iframe.src !== videoSources[i]) {
          iframe.src = videoSources[i];
        }
      } else {
        video.style.display = "none";
        // 非表示にする動画のiframeを停止（srcを空にするのみ）
        const iframe = video.querySelector("iframe");
        if (iframe && iframe.src) {
          iframe.src = "";
        }
      }
    });

    if (counter) {
      counter.textContent = `${index + 1} / ${totalVideos}`;
    }

    currentVideoIndex = index;
  }

  function nextVideo() {
    const nextIndex = (currentVideoIndex + 1) % totalVideos;
    showVideo(nextIndex);
  }

  function prevVideo() {
    const prevIndex = (currentVideoIndex - 1 + totalVideos) % totalVideos;
    showVideo(prevIndex);
  }

  // ===== ギャラリー 画像データ =====
  const ILLUST_IMAGES = [
    { src: "https://picsum.photos/seed/10/800/520",  title: "Cat Sketch #1" },
    { src: "https://picsum.photos/seed/20/800/520",  title: "Fantasy Landscape" },
    { src: "https://picsum.photos/seed/30/800/520",  title: "Pixel Character" },
    { src: "https://picsum.photos/seed/40/800/520",  title: "Night City" },
    { src: "https://picsum.photos/seed/50/800/520",  title: "Portrait Study" },
    { src: "https://picsum.photos/seed/60/800/520",  title: "Abstract Flow" },
    { src: "https://picsum.photos/seed/70/800/520",  title: "Creature Design" },
    { src: "https://picsum.photos/seed/80/800/520",  title: "Neon Alley" },
    { src: "https://picsum.photos/seed/90/800/520",  title: "Chibi Character" },
    { src: "https://picsum.photos/seed/100/800/520", title: "Scenery Draft" },
  ];

  let currentIllustIndex = 0;

  function showIllust(index) {
    const img     = document.getElementById("viewer-img");
    const num     = document.getElementById("viewer-num");
    const title   = document.getElementById("viewer-title");
    const counter = document.getElementById("viewer-counter");
    const dots    = document.querySelectorAll(".viewer-dot");

    if (!img) return;

    const data = ILLUST_IMAGES[index];
    img.style.opacity = "0";
    setTimeout(() => {
      img.src = data.src;
      img.alt = data.title;
      img.style.opacity = "1";
    }, 150);

    if (num)     num.textContent     = `NO.${String(index + 1).padStart(2, "0")}`;
    if (title)   title.textContent   = `[ ${data.title} ]`;
    if (counter) counter.textContent = `${String(index + 1).padStart(2, "0")} / ${ILLUST_IMAGES.length}`;

    dots.forEach((dot, i) => dot.classList.toggle("active", i === index));
    currentIllustIndex = index;
  }

  // ===== ギャラリーフィルター =====
  const FILTERS = [
    { key: "none", label: "NORMAL",   desc: "NO FILTER APPLIED",       mode: "" },
    { key: "crt",  label: "CRT",      desc: "PHOSPHOR + SCANLINES",     mode: "mode-crt" },
    { key: "gb",   label: "G・BOY",   desc: "4-COLOR GREEN PALETTE",    mode: "mode-gb" },
    { key: "vhs",  label: "VHS",      desc: "RGB SHIFT + TRACKING",     mode: "mode-vhs" },
  ];

  let currentFilterIndex = 0;

  function applyFilter(index) {
    const f      = FILTERS[index];
    const frame  = document.getElementById("viewer-frame");
    const display = document.getElementById("filter-display");
    const desc   = document.getElementById("filter-desc");
    const chips  = document.querySelectorAll(".filter-chip");

    if (!frame || !display || !desc) return;

    frame.classList.remove("filter-crt", "filter-gb", "filter-vhs");
    if (f.key !== "none") frame.classList.add(`filter-${f.key}`);

    display.textContent = f.label;
    display.className   = `console-screen-main ${f.mode}`;
    desc.textContent    = f.desc;

    chips.forEach((chip) => {
      const active = chip.dataset.filter === f.key;
      chip.classList.toggle("active", active);
      chip.setAttribute("aria-pressed", String(active));
    });

    currentFilterIndex = index;
  }

  // DOM読み込み完了後に実行
  document.addEventListener("DOMContentLoaded", function () {
    const copyIcon = document.getElementById("copy-crosshair-text");
    if (copyIcon) {
      copyIcon.addEventListener("click", copyCrosshairCode);
    }

    const prevBtn = document.getElementById("prev-video-btn");
    if (prevBtn) {
      prevBtn.addEventListener("click", prevVideo);
    }

    const nextBtn = document.getElementById("next-video-btn");
    if (nextBtn) {
      nextBtn.addEventListener("click", nextVideo);
    }

    // 動画のオリジナルsrcを保存
    initializeVideoSources();

    // フィルターコンソール
    // フィルターコンソール
    document.getElementById("filter-prev")?.addEventListener("click", () => {
      applyFilter((currentFilterIndex - 1 + FILTERS.length) % FILTERS.length);
    });

    document.getElementById("filter-next")?.addEventListener("click", () => {
      applyFilter((currentFilterIndex + 1) % FILTERS.length);
    });

    document.querySelectorAll(".filter-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        const key = (chip as HTMLElement).dataset.filter;
        const idx = FILTERS.findIndex((f) => f.key === key);
        if (idx !== -1) applyFilter(idx);
      });
    });

    // 画像ナビゲーション
    document.getElementById("illust-prev")?.addEventListener("click", () => {
      showIllust((currentIllustIndex - 1 + ILLUST_IMAGES.length) % ILLUST_IMAGES.length);
    });

    document.getElementById("illust-next")?.addEventListener("click", () => {
      showIllust((currentIllustIndex + 1) % ILLUST_IMAGES.length);
    });

    document.querySelectorAll(".viewer-dot").forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = parseInt((dot as HTMLElement).dataset.index ?? "0", 10);
        showIllust(idx);
      });
    });

    // キーボード操作（←→）
    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft")  showIllust((currentIllustIndex - 1 + ILLUST_IMAGES.length) % ILLUST_IMAGES.length);
      if (e.key === "ArrowRight") showIllust((currentIllustIndex + 1) % ILLUST_IMAGES.length);
    });
  });
</script>

