---
import competitiveAgentData from '../data/competitive_agent.json';
import clipsRaw from '../data/clips.json';
import gamesData from '../data/games.json';
import competitiveRankData from '../data/competitive_rank.json';
import competitiveWeaponData from '../data/competitive_weapon.json';
import competitiveMapData from '../data/competitive_map.json';
import unratedAgentData from '../data/unrate_agent.json';
import unratedPerformanceData from '../data/unrate_performance.json';
import deathmatchPerformanceData from '../data/deathmatch_performance.json';
import SimpleLayout from "../layouts/SimpleLayout.astro";
import ValorantStats from "../components/charts/ValorantStats.astro";
import YouTubeClipViewer from "../components/YouTubeClipViewer.astro";
import GameBoyGallery from "../components/GameBoyGallery.astro";
import WiiUGamepad from "../components/WiiUGamepad.astro";
import DSLite from "../components/DSLite.astro";
import { applyTypographyPreset } from "../utils/typography";
import {
  getCurrentThemeColors,
  FIXED_COLORS,
  FONT_SIZES,
  FONTS,
  getStylePresets,
} from "../config/themeConfig";
import "../styles/global.css";

// テーマカラー統合オブジェクト
const themeColors = getCurrentThemeColors();
const COLORS = { ...themeColors, ...FIXED_COLORS };

// スタイルプリセット（テンプレート内で S.title, S.bodyText 等で使用）
const S = getStylePresets(COLORS);

// クリップギャラリーデータ（src/data/clips.json で管理・scoreの合計が高いほど上位）
interface ClipScore { smooth: number; clutch: number; tap: number; "6kills": number; onemag: number; }
interface ClipData  { id: string; url: string; title: string; map: string; agent: string; views: number; tags: string[]; score: ClipScore; }
const CLIPS_INITIAL_SHOW = 6;

const SCORE_DEFAULTS: ClipScore = { smooth: 2, clutch: 0, tap: 3, "6kills": 0, onemag: 0 };

const TAG_LABELS: Record<string, string> = {
  op:          'OP',
  guardian:    'Guardian',
  ghost:       'Ghost',
  bundit:      'Bundit',
  vandal:      'Vandal',
  bucky:       'Bucky',
  spectre:     'Spectre',
  classic:     'Classic',
  '6kills':    '6kills',
  smooth:      'Smooth',
  onemagazine: '1Mag',
};

type TagBadge = { label: string; type: string; value: string };

// タイトル + JSONタグを統合してバッジリストを生成
function getClipTags(title: string, jsonTags: string[]): TagBadge[] {
  const t = title.toLowerCase();
  const result: TagBadge[] = [];
  if (t.includes('ult')) result.push({ label: 'Ult', type: 'kw', value: 'ult' });
  for (const tag of jsonTags) {
    if (tag === 'clutch') {
      const m = t.match(/(\d)v(\d)/);
      result.push({ label: m ? `${m[1]}v${m[2]}` : 'Clutch', type: 'kw', value: 'clutch' });
    } else {
      result.push({ label: TAG_LABELS[tag] ?? tag, type: 'kw', value: tag });
    }
  }
  return result;
}

function totalScore(c: ClipData) {
  const s = c.score;
  return (s.smooth    ?? SCORE_DEFAULTS.smooth)
       + (s.clutch    ?? SCORE_DEFAULTS.clutch)
       + (s.tap       ?? SCORE_DEFAULTS.tap)
       + (s["6kills"] ?? SCORE_DEFAULTS["6kills"])
       + (s.onemag    ?? SCORE_DEFAULTS.onemag);
}

// デフォルト: スコア合計の高い順
const clipGalleryData: ClipData[] = [...(clipsRaw as ClipData[])].sort(
  (a, b) => totalScore(b) - totalScore(a)
);
const clipMaps   = [...new Set(clipGalleryData.map(c => c.map))];
const clipAgents = [...new Set(clipGalleryData.map(c => c.agent))];
function capFirst(s: string) { return s.charAt(0).toUpperCase() + s.slice(1); }

// フィルター件数カウント（ビルド時に静的計算）
const mapCounts = Object.fromEntries(
  clipMaps.map(m => [m, clipGalleryData.filter(c => c.map === m).length])
);
const agentCounts = Object.fromEntries(
  clipAgents.map(a => [a, clipGalleryData.filter(c => c.agent === a).length])
);
const typeCounts: Record<string, number> = {
  all:         clipGalleryData.length,
  clutch:      clipGalleryData.filter(c => c.tags.includes('clutch')).length,
  ult:         clipGalleryData.filter(c => /ult/i.test(c.title)).length,
  onemagazine: clipGalleryData.filter(c => c.tags.includes('onemagazine')).length,
  smooth:      clipGalleryData.filter(c => c.tags.includes('smooth')).length,
  '6kills':    clipGalleryData.filter(c => c.tags.includes('6kills')).length,
  vandal:      clipGalleryData.filter(c => c.tags.includes('vandal')).length,
  ghost:       clipGalleryData.filter(c => c.tags.includes('ghost')).length,
  guardian:    clipGalleryData.filter(c => c.tags.includes('guardian')).length,
  bundit:      clipGalleryData.filter(c => c.tags.includes('bundit')).length,
  op:          clipGalleryData.filter(c => c.tags.includes('op')).length,
  bucky:       clipGalleryData.filter(c => c.tags.includes('bucky')).length,
  spectre:     clipGalleryData.filter(c => c.tags.includes('spectre')).length,
  classic:     clipGalleryData.filter(c => c.tags.includes('classic')).length,
};
const fpsGames    = gamesData.filter((g: any) => g.category === "FPS");
const socialGames = gamesData.filter((g: any) => g.category === "ソシャゲ");
