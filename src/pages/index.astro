                                    ` WIN RATE  : ${agent.win_rate}%`,
                                    ` K/D RATIO : ${agent.kd.toFixed(2)}`,
                                    ` ADR       : ${agent.adr}`,
                                    ` ACS       : ${agent.acs}`,
                                    ` HS RATE   : ${agent.hs}%`,
                                    ` KAST      : ${agent.kast}%`
                                ];
                            }
                        }
                    }
                }
            }
        }) : null;
        const syncAgentThresholdLabel = () => {
            if (agentThresholdDisplay) agentThresholdDisplay.textContent = `MATCHES ≥ ${agentThreshold}`;
        };
        const refreshAgentChart = () => {
            if (!agentChart) return;
            const filtered = getAgentFilteredData();
            agentChart.data.labels = filtered.map(a => a.name);
            agentChart.data.datasets[0].data = filtered.map(a => a[agentCurrentStat]);
            agentChart.data.datasets[0].pointBackgroundColor = filtered.map(a => agentColors[a.name] || THEME_COLOR);
            if (filtered.length === 0) {
                agentChart.options.scales.y.min = 0;
                agentChart.options.scales.y.max = 1;
                agentChart.options.scales.y.ticks.stepSize = 0.2;
                agentChart.options.scales.y.ticks.callback = v => v;
                agentChart.options._baselineValue = null;
                agentChart.update();
                return;
            }
            const isPct = ['win_rate', 'hs', 'kast'].includes(agentCurrentStat);
            if (isPct) {
                agentChart.options.scales.y.min = 0;
                agentChart.options.scales.y.max = 100;
                agentChart.options.scales.y.ticks.stepSize = 10;
                agentChart.options.scales.y.ticks.callback = v => `${v}%`;
            } else if (agentCurrentStat === 'kd') {
                const s = kdScale(filtered.map(a => a.kd));
                agentChart.options.scales.y.min = s.min;
                agentChart.options.scales.y.max = s.max;
                agentChart.options.scales.y.ticks.stepSize = s.step;
                agentChart.options.scales.y.ticks.callback = v => v.toFixed(1);
            } else {
                agentChart.options.scales.y.min = 0;
                agentChart.options.scales.y.max = undefined;
                agentChart.options.scales.y.ticks.stepSize = undefined;
                agentChart.options.scales.y.ticks.callback = v => v;
            }
            agentChart.options._baselineValue = agentCurrentStat === 'kd' ? 1.0 : null;
            agentChart.update();
        };
        window.updateAgentThreshold = function(val) {
            agentThreshold = parseInt(val, 10) || 0;
            syncAgentThresholdLabel();
            refreshAgentChart();
        };
        window.toggleAgentRole = function(role) {
            if (activeAgentRoles.has(role)) {
                activeAgentRoles.delete(role);
            } else {
                activeAgentRoles.add(role);
            }
            const btn = document.getElementById(`btn-role-${role.toLowerCase()}`);
            if (btn) btn.classList.toggle('active', activeAgentRoles.has(role));
            refreshAgentChart();
        };
        window.updateAgentStat = function(stat) {
            if (agentCurrentStat === stat) return;
            agentCurrentStat = stat;
            document.querySelectorAll('.agent-stat-controls button').forEach(btn => btn.classList.remove('active'));
            const activeBtn = document.getElementById(`btn-a-${stat}`);
            if (activeBtn) activeBtn.classList.add('active');
            refreshAgentChart();
        };
        syncAgentThresholdLabel();
        refreshAgentChart();

        // UPDATE FUNCTIONS (window に登録してonclickからアクセス可能にする)
        window.updateRankChart = function(mode) {
            document.querySelectorAll('[id^="btn-r-"]').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-r-${mode}`).classList.add('active');
            let isRank = (mode === 'rank');
            let isCumulative = (mode === 'playtime_cumulative');
            if (isCumulative) {
                let cumulative = 0;
                rChart.data.datasets[0].data = rankData.map(d => { cumulative += d.playtime; return Math.round(cumulative * 10) / 10; });
            } else {
                rChart.data.datasets[0].data = isRank ? rankData.map(d => allRanks.indexOf(d.rank)) : (mode === 'kd' ? rankData.map(d => d.kd) : rankData.map(d => d[mode === 'hs' ? 'hs' : mode] * (mode === 'playtime' || mode === 'wins' ? 1 : 100)));
            }
            if (isRank) { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = 24; rChart.options.scales.y.ticks.stepSize = 1; rChart.options.scales.y.ticks.callback = rankLabelFunc; }
            else if (mode === 'kd') { const s = kdScale(rankData.map(d => d.kd)); rChart.options.scales.y.min = s.min; rChart.options.scales.y.max = s.max; rChart.options.scales.y.ticks.stepSize = s.step; rChart.options.scales.y.ticks.callback = v => v.toFixed(1); }
            else if (mode === 'win_rate') { const s = wrScale(rankData.map(d => d.win_rate * 100)); rChart.options.scales.y.min = s.min; rChart.options.scales.y.max = s.max; rChart.options.scales.y.ticks.stepSize = s.step; rChart.options.scales.y.ticks.callback = v => v + '%'; }
            else if (mode === 'hs') { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = 100; rChart.options.scales.y.ticks.stepSize = 10; rChart.options.scales.y.ticks.callback = v => v + '%'; }
            else if (isCumulative) { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = undefined; rChart.options.scales.y.ticks.stepSize = undefined; rChart.options.scales.y.ticks.callback = v => v + 'h'; }
            else { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = undefined; rChart.options.scales.y.ticks.stepSize = undefined; rChart.options.scales.y.ticks.callback = v => v; }
            rChart.options._baselineValue = mode === 'kd' ? 1.0 : mode === 'win_rate' ? 50 : null;
            rChart.update();
        }

        function refreshWeaponChart() {
            wChart.data.labels = filteredWeapons.map(w => w.weapon);
            const mode = currentWeaponMode;
            wChart.data.datasets[0].data = filteredWeapons.map(w => mode === 'hs_rate' ? (w.hs_rate * 100).toFixed(1) : w[mode]);
            if (mode === 'hs_rate') { wChart.options.scales.y.min = 0; wChart.options.scales.y.max = 100; wChart.options.scales.y.ticks.stepSize = 10; wChart.options.scales.y.ticks.callback = v => v + '%'; }
            else if (mode === 'kd') { const s = kdScale(filteredWeapons.map(w => w.kd)); wChart.options.scales.y.min = s.min; wChart.options.scales.y.max = s.max; wChart.options.scales.y.ticks.stepSize = s.step; wChart.options.scales.y.ticks.callback = v => v.toFixed(1); }
            else { wChart.options.scales.y.min = 0; wChart.options.scales.y.max = undefined; wChart.options.scales.y.ticks.stepSize = undefined; wChart.options.scales.y.ticks.callback = v => v; }
            wChart.options._baselineValue = mode === 'kd' ? 1.0 : null;
            wChart.update();
        }

        const syncWeaponCatButtons = () => {
            allWeaponCats.forEach(c => document.getElementById(`btn-wc-${c}`).classList.toggle('active', activeWeaponCategories.has(c)));
            document.getElementById('btn-wc-all').classList.toggle('active', activeWeaponCategories.size === allWeaponCats.length);
        };
        window.toggleWeaponCategory = function(cat) {
            if (activeWeaponCategories.has(cat)) { if (activeWeaponCategories.size > 1) activeWeaponCategories.delete(cat); }
            else activeWeaponCategories.add(cat);
            syncWeaponCatButtons();
            filteredWeapons = getFilteredWeapons();
            refreshWeaponChart();
        }
        window.toggleAllWeaponCategories = function() {
            if (activeWeaponCategories.size === allWeaponCats.length) { activeWeaponCategories = new Set(['assault']); }
            else { activeWeaponCategories = new Set(allWeaponCats); }
            syncWeaponCatButtons();
            filteredWeapons = getFilteredWeapons();
            refreshWeaponChart();
        }

        window.updateWeaponChart = function(mode) {
            document.querySelectorAll('[id^="btn-w-"]').forEach(b => b.classList.remove('active'));
            document.getElementById(mode === 'kpr' ? 'btn-w-kpr' : `btn-w-${mode}`).classList.add('active');
            currentWeaponMode = mode;
            refreshWeaponChart();
        }

        window.updateMapChart = function(mode) {
            document.querySelectorAll('[id^="btn-m-"]').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-m-${mode}`).classList.add('active');
            mChart.data.datasets[0].data = mapData.map(m => mode === 'win_rate' ? (m.win_rate * 100).toFixed(1) : m[mode]);
            if (mode === 'win_rate') { const s = wrScale(mapData.map(m => m.win_rate * 100)); mChart.options.scales.y.min = s.min; mChart.options.scales.y.max = s.max; mChart.options.scales.y.ticks.stepSize = s.step; mChart.options.scales.y.ticks.callback = v => v + '%'; }
            else if (mode === 'kd') { const s = kdScale(mapData.map(m => m.kd)); mChart.options.scales.y.min = s.min; mChart.options.scales.y.max = s.max; mChart.options.scales.y.ticks.stepSize = s.step; mChart.options.scales.y.ticks.callback = v => v.toFixed(1); }
            else { mChart.options.scales.y.min = 0; mChart.options.scales.y.max = undefined; mChart.options.scales.y.ticks.stepSize = undefined; mChart.options.scales.y.ticks.callback = v => v; }
            mChart.options._baselineValue = mode === 'kd' ? 1.0 : mode === 'win_rate' ? 50 : null;
            mChart.update();
        }

        let currentGameMode = 'competitive';
        window.switchGameMode = function(mode) {
            if (mode === currentGameMode) return;
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-mode-${mode}`).classList.add('active');
            currentGameMode = mode;
            const grid = document.getElementById('charts-grid');
            const msg = document.getElementById('mode-unavailable');
            if (mode === 'competitive') { grid.style.display = ''; msg.style.display = 'none'; }
            else { grid.style.display = 'none'; msg.style.display = ''; }
        }
});
</script>
