        // 1. RANK CHART INIT
        const rChart = new Chart(document.getElementById('rankChart').getContext('2d'), {
            type: 'line', data: { labels: rankData.map(d => d.act_id), datasets: [{ data: rankData.map(d => allRanks.indexOf(d.rank)), borderColor: THEME_COLOR, borderWidth: 2, pointStyle: 'rect', pointRadius: getResponsiveRadius, pointBackgroundColor: rankData.map(d => rankColors[d.rank.split(' ')[0]] || THEME_COLOR), pointBorderColor: '#fff', pointBorderWidth: 1, tension: 0 }] },
            options: { ...commonOptions, scales: { y: { min: 0, max: 24, ticks: { stepSize: 1, callback: rankLabelFunc }, grid: { color: (c) => c.tick.value % 3 === 0 ? GRID_COLOR : GRID_COLOR.replace('0.4)', '0.1)'), lineWidth: (c) => c.tick.value % 3 === 0 ? 2 : 1 } } }, plugins: { ...commonOptions.plugins, tooltip: { ...commonOptions.plugins.tooltip, callbacks: { label: (item) => { const d = rankData[item.dataIndex]; return [` RANK    : ${d.rank}`, ` PLAYTIME: ${d.playtime}h`, ` WINS    : ${d.wins}`, ` WIN %   : ${(d.win_rate * 100).toFixed(1)}%`, ` K/D     : ${d.kd.toFixed(2)}`, ` HS%     : ${(d.hs * 100).toFixed(1)}%`]; } } } } }
        });

        // 2. WEAPON CHART INIT
        const wChart = new Chart(document.getElementById('weaponChart').getContext('2d'), {
            type: 'line', data: { labels: weaponData.map(w => w.weapon), datasets: [{ data: weaponData.map(w => w.kills), borderColor: THEME_COLOR, borderWidth: 2, pointStyle: 'rect', pointRadius: getResponsiveRadius, pointBackgroundColor: THEME_COLOR, tension: 0 }] },
            options: { ...commonOptions, scales: { x: { ticks: { color: THEME_COLOR, autoSkip: false, maxRotation: 45, minRotation: 45 } }, y: { ticks: { color: THEME_COLOR }, grid: { color: GRID_COLOR, lineWidth: 1 } } }, plugins: { ...commonOptions.plugins, tooltip: { ...commonOptions.plugins.tooltip, callbacks: { label: (item) => { const w = weaponData[item.dataIndex]; return [` KILLS   : ${w.kills}`, ` DEATHS  : ${w.deaths}`, ` K/D     : ${w.kd.toFixed(2)}`, ` HS %    : ${(w.hs_rate * 100).toFixed(1)}%`, ` ADR     : ${w.adr}`, ` K/ROUND : ${w.kpr}`]; } } } } }
        });

        // 3. MAP CHART INIT
        const mChart = new Chart(document.getElementById('mapChart').getContext('2d'), {
            type: 'line', data: { labels: mapData.map(m => m.map), datasets: [{ data: mapData.map(m => (m.win_rate * 100).toFixed(1)), borderColor: THEME_COLOR, borderWidth: 2, pointStyle: 'rect', pointRadius: getResponsiveRadius, pointBackgroundColor: THEME_COLOR, tension: 0 }] },
            options: { ...commonOptions, scales: { y: { min: 0, max: 100, ticks: { stepSize: 10, callback: v => v + '%' }, grid: { color: GRID_COLOR, lineWidth: 1.5 } }, x: { grid: { color: GRID_COLOR, lineWidth: 1.5 } } }, plugins: { ...commonOptions.plugins, tooltip: { ...commonOptions.plugins.tooltip, callbacks: { label: (item) => { const m = mapData[item.dataIndex]; return [` WIN %   : ${(m.win_rate * 100).toFixed(1)}%`, ` MATCHES : ${m.wins + m.losses}`, ` W / L   : ${m.wins} / ${m.losses}`, ` K/D     : ${m.kd.toFixed(2)}`, ` ADR     : ${m.adr}`, ` ACS     : ${m.acs}`]; } } } } }
        });

        // UPDATE FUNCTIONS (window に登録してonclickからアクセス可能にする)
        window.updateRankChart = function(mode) {
            document.querySelectorAll('[id^="btn-r-"]').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-r-${mode}`).classList.add('active');
            let isRank = (mode === 'rank');
            rChart.data.datasets[0].data = isRank ? rankData.map(d => allRanks.indexOf(d.rank)) : (mode === 'kd' ? rankData.map(d => d.kd) : rankData.map(d => d[mode === 'hs' ? 'hs' : mode] * (mode === 'playtime' || mode === 'wins' ? 1 : 100)));
            if (isRank) { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = 24; rChart.options.scales.y.ticks.stepSize = 1; rChart.options.scales.y.ticks.callback = rankLabelFunc; }
            else if (mode === 'kd') { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = 2; rChart.options.scales.y.ticks.stepSize = 0.2; rChart.options.scales.y.ticks.callback = v => v; }
            else if (mode === 'win_rate' || mode === 'hs') { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = 100; rChart.options.scales.y.ticks.stepSize = 10; rChart.options.scales.y.ticks.callback = v => v + '%'; }
            else { rChart.options.scales.y.min = 0; rChart.options.scales.y.max = undefined; rChart.options.scales.y.ticks.stepSize = undefined; rChart.options.scales.y.ticks.callback = v => v; }
            rChart.update();
        }

        window.updateWeaponChart = function(mode) {
            document.querySelectorAll('[id^="btn-w-"]').forEach(b => b.classList.remove('active'));
            document.getElementById(mode === 'kpr' ? 'btn-w-kpr' : `btn-w-${mode}`).classList.add('active');
            wChart.data.datasets[0].data = weaponData.map(w => mode === 'hs_rate' ? (w.hs_rate * 100).toFixed(1) : w[mode]);
            if (mode === 'hs_rate') { wChart.options.scales.y.min = 0; wChart.options.scales.y.max = 100; wChart.options.scales.y.ticks.stepSize = 10; wChart.options.scales.y.ticks.callback = v => v + '%'; }
            else if (mode === 'kd') {
                wChart.options.scales.y.min = 0; wChart.options.scales.y.max = 5;
                wChart.options.scales.y.ticks.stepSize = 0.5; // 0.5刻み設定
                wChart.options.scales.y.ticks.callback = v => v.toFixed(1);
            }
            else { wChart.options.scales.y.min = 0; wChart.options.scales.y.max = undefined; wChart.options.scales.y.ticks.stepSize = undefined; wChart.options.scales.y.ticks.callback = v => v; }
            wChart.update();
        }

        window.updateMapChart = function(mode) {
            document.querySelectorAll('[id^="btn-m-"]').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-m-${mode}`).classList.add('active');
            mChart.data.datasets[0].data = mapData.map(m => mode === 'win_rate' ? (m.win_rate * 100).toFixed(1) : m[mode]);
            if (mode === 'win_rate') { mChart.options.scales.y.min = 0; mChart.options.scales.y.max = 100; mChart.options.scales.y.ticks.stepSize = 10; mChart.options.scales.y.ticks.callback = v => v + '%'; }
            else if (mode === 'kd') { mChart.options.scales.y.min = 0; mChart.options.scales.y.max = 2; mChart.options.scales.y.ticks.stepSize = 0.2; mChart.options.scales.y.ticks.callback = v => v; }
            else { mChart.options.scales.y.min = 0; mChart.options.scales.y.max = undefined; mChart.options.scales.y.ticks.stepSize = undefined; mChart.options.scales.y.ticks.callback = v => v; }
            mChart.update();
        }
});
</script>
