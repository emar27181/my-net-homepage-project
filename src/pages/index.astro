    border: 1px solid rgba(77, 121, 255, 0.3);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .clip-card:hover {
    border-color: var(--text-accessible-blue);
    transform: translateY(-2px);
  }

  .clip-thumbnail-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    cursor: pointer;
    overflow: hidden;
    background: #000;
  }

  .clip-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.2s ease;
  }

  .clip-thumbnail-wrapper:hover .clip-thumb-img {
    filter: brightness(0.55);
  }

  .clip-play-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 2rem;
    color: var(--text-accessible-blue);
    text-shadow: 0 0 15px var(--text-accessible-blue), 1px 1px 0 #000;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    image-rendering: pixelated;
  }

  .clip-thumbnail-wrapper:hover .clip-play-overlay {
    opacity: 1;
  }

  .clip-thumbnail-wrapper.playing .clip-thumb-img,
  .clip-thumbnail-wrapper.playing .clip-play-overlay {
    display: none;
  }

  .clip-thumbnail-wrapper.playing iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
  }

  .clip-meta {
    display: flex;
    gap: 5px;
    padding: 6px 8px;
    flex-wrap: wrap;
  }

  .clip-map-badge,
  .clip-agent-badge {
    font-family: var(--font-pixel);
    font-size: var(--fs-small);
    padding: 2px 6px;
    border-radius: 2px;
    text-shadow: 1px 1px 0 #000;
    image-rendering: pixelated;
    white-space: nowrap;
  }

  .clip-map-badge {
    background: rgba(77, 121, 255, 0.2);
    color: #99bbff;
    border: 1px solid rgba(77, 121, 255, 0.4);
  }

  .clip-agent-badge {
    background: rgba(128, 0, 255, 0.2);
    color: #cc99ff;
    border: 1px solid rgba(128, 0, 255, 0.4);
  }

  .clip-kw-badge {
    font-family: var(--font-pixel);
    font-size: var(--fs-small);
    padding: 2px 6px;
    border-radius: 2px;
    text-shadow: 1px 1px 0 #000;
    image-rendering: pixelated;
    white-space: nowrap;
    background: rgba(255, 160, 0, 0.15);
    color: #ffcc66;
    border: 1px solid rgba(255, 160, 0, 0.4);
  }

  .clips-expand-btn {
    font-family: var(--font-pixel-jp);
    font-size: var(--fs-body);
    padding: 8px 22px;
    background: rgba(77, 121, 255, 0.12);
    color: var(--text-accessible-blue);
    border: 2px solid rgba(77, 121, 255, 0.45);
    border-radius: 4px;
    cursor: pointer;
    text-shadow: 1px 1px 0 #000, 0 0 8px var(--text-accessible-blue);
    image-rendering: pixelated;
    transition: all 0.2s ease;
  }

  .clips-expand-btn:hover {
    background: rgba(77, 121, 255, 0.28);
    border-color: var(--text-accessible-blue);
    transform: scale(1.04);
  }

  @media (max-width: 768px) {
    .clips-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function copyCrosshairCode() {
    navigator.clipboard.writeText(
      "0;p;0;s;1;P;c;8;u;0077FFFF;o;0.3;b;1;f;0;0t;1;0l;5;0v;5;0o;2;0a;1;0f;0;1t;3;1o;2;1a;1;1m;0;1f;0;A;c;5;u;0077FFFF;o;0.2;0t;3;0l;1;0v;1;0o;1;0a;1;0f;0;1b;0;S;c;5",
    );

    // アイコンとテキストを切り替え
    const copyIcon = document.getElementById("copy-crosshair-icon");
    const checkIcon = document.getElementById("check-crosshair-icon");
    const label = document.getElementById("copy-crosshair-label");

    if (copyIcon && checkIcon && label) {
      copyIcon.style.display = "none";
      checkIcon.style.display = "inline-block";
      label.textContent = "コピーしました！";

      // 2秒後に元に戻す
      setTimeout(() => {
        checkIcon.style.display = "none";
        copyIcon.style.display = "inline-block";
        label.textContent = "クロスヘアコードをコピー";
      }, 2000);
    }
  }

  let currentVideoIndex = 0;
  const totalVideos = 8;
  let videoSources = []; // 各動画のオリジナルsrcを保存

  function initializeVideoSources() {
    const videos = document.querySelectorAll(".carousel-video");
    videos.forEach((video, i) => {
      const iframe = video.querySelector("iframe");
      if (iframe && iframe.src) {
        videoSources[i] = iframe.src;
      }
    });
  }

  function showVideo(index) {
    const videos = document.querySelectorAll(".carousel-video");
    const counter = document.getElementById("video-counter");

    videos.forEach((video, i) => {
      if (i === index) {
        video.style.display = "block";
        // 表示する動画のsrcを復元（黒画面を防ぐ）
        const iframe = video.querySelector("iframe");
        if (iframe && videoSources[i] && iframe.src !== videoSources[i]) {
          iframe.src = videoSources[i];
        }
      } else {
        video.style.display = "none";
        // 非表示にする動画のiframeを停止（srcを空にするのみ）
        const iframe = video.querySelector("iframe");
        if (iframe && iframe.src) {
          iframe.src = "";
        }
      }
    });

    if (counter) {
      counter.textContent = `${index + 1} / ${totalVideos}`;
    }

    currentVideoIndex = index;
  }

  function nextVideo() {
    const nextIndex = (currentVideoIndex + 1) % totalVideos;
    showVideo(nextIndex);
  }

  function prevVideo() {
    const prevIndex = (currentVideoIndex - 1 + totalVideos) % totalVideos;
    showVideo(prevIndex);
  }

  // DOM読み込み完了後に実行
  document.addEventListener("DOMContentLoaded", function () {
    const copyIcon = document.getElementById("copy-crosshair-text");
    if (copyIcon) {
      copyIcon.addEventListener("click", copyCrosshairCode);
    }

    const prevBtn = document.getElementById("prev-video-btn");
    if (prevBtn) {
      prevBtn.addEventListener("click", prevVideo);
    }

    const nextBtn = document.getElementById("next-video-btn");
    if (nextBtn) {
      nextBtn.addEventListener("click", nextVideo);
    }

    // 動画のオリジナルsrcを保存
    initializeVideoSources();

    // ===== ゲーム詳細モーダル =====
    const overlay    = document.getElementById('game-modal') as HTMLElement;
    const gmTitle    = document.getElementById('gm-title');
    const gmCat      = document.getElementById('gm-category');
    const gmTime     = document.getElementById('gm-playtime');
    const gmPeriod   = document.getElementById('gm-period');
    const gmRank     = document.getElementById('gm-maxrank');
    const gmCom      = document.getElementById('gm-comment');
    const gmPidRow   = document.getElementById('gm-playerid-row');
    const gmPid      = document.getElementById('gm-playerid');
    const gmTrnRow    = document.getElementById('gm-trn-row');
    const gmTrnLink   = document.getElementById('gm-trn-link') as HTMLAnchorElement | null;
    const gmInPageRow = document.getElementById('gm-inpage-row');
    const gmInPageLink= document.getElementById('gm-inpage-link') as HTMLAnchorElement | null;

    function openGameModal(g: any) {
      if (!overlay || !gmTitle || !gmCat || !gmTime || !gmPeriod || !gmRank || !gmCom) return;
      gmTitle.textContent  = g.name.toUpperCase() + (g.note ? ` (${g.note})` : '');
      gmCat.textContent    = g.category;
      gmTime.textContent   = g.playTime;
      gmPeriod.textContent = g.period;
      gmRank.textContent   = g.maxRank;
      gmCom.textContent    = g.comment;
      if (gmPid && gmPidRow) {
        if (g.playerId) {
          gmPid.textContent = g.playerId;
          (gmPidRow as HTMLElement).style.display = '';
        } else {
          (gmPidRow as HTMLElement).style.display = 'none';
        }
      }
      if (gmTrnLink && gmTrnRow) {
        if (g.trnUrl) {
          gmTrnLink.href = g.trnUrl;
          (gmTrnRow as HTMLElement).style.display = '';
        } else {
          (gmTrnRow as HTMLElement).style.display = 'none';
        }
      }
      if (gmInPageLink && gmInPageRow) {
        if (g.inPageUrl) {
          gmInPageLink.href = g.inPageUrl;
          gmInPageLink.onclick = () => closeGameModal();
          (gmInPageRow as HTMLElement).style.display = '';
        } else {
          (gmInPageRow as HTMLElement).style.display = 'none';
        }
      }
      overlay.classList.add('open');
      overlay.removeAttribute('aria-hidden');
    }

    function closeGameModal() {
      overlay?.classList.remove('open');
      overlay?.setAttribute('aria-hidden', 'true');
    }

    // ツールチップ
    const tooltip   = document.getElementById('game-tooltip') as HTMLElement;
    const gtName    = document.getElementById('gt-name');
    const gtTime    = document.getElementById('gt-playtime');
    const gtRank    = document.getElementById('gt-maxrank');
    let tooltipTimer: ReturnType<typeof setTimeout>;

    function showTooltip(el: HTMLElement, g: any) {
      if (!tooltip || !gtName || !gtTime || !gtRank) return;
      gtName.textContent  = g.name.toUpperCase();
      gtTime.textContent  = g.playTime;
      gtRank.textContent  = g.maxRank;
      const rect = el.getBoundingClientRect();
      tooltip.style.left = `${rect.left}px`;
      tooltip.style.top  = `${rect.bottom + 6}px`;
      tooltip.classList.add('visible');
    }

    function hideTooltip() {
      tooltip?.classList.remove('visible');
    }

    document.querySelectorAll('.game-chip').forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        clearTimeout(tooltipTimer);
        const raw = (btn as HTMLElement).dataset.gameJson;
        if (raw) showTooltip(btn as HTMLElement, JSON.parse(raw));
      });
      btn.addEventListener('mouseleave', () => {
        tooltipTimer = setTimeout(hideTooltip, 150);
      });
      btn.addEventListener('click', () => {
        hideTooltip();
        const raw = (btn as HTMLElement).dataset.gameJson;
        if (raw) openGameModal(JSON.parse(raw));
      });
    });

    document.getElementById('gm-close')?.addEventListener('click', closeGameModal);
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) closeGameModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeGameModal();
    });
  });

  // ===== クリップギャラリー =====
  (function () {
    const INITIAL = 6;
    let activeMap   = 'all';
    let activeAgent = 'all';
    let activeKw    = 'all';
    type SortMode = 'custom' | 'views';
    let sortMode: SortMode = 'custom';
    let expanded    = false;

    // キーワードマッチ（OPのみ単語境界チェック）
    const KW_PATTERNS: Record<string, RegExp> = {
      clutch: /clutch/i,
      vandal: /vandal/i,
      op:     /\bop\b|opace/i,
      ult:    /ult/i,
    };

    function allCards() {
      return Array.from(document.querySelectorAll('.clip-card')) as HTMLElement[];
    }

    function filtered() {
      return allCards().filter(card => {
        const mapOk   = activeMap   === 'all' || card.dataset.map   === activeMap;
        const agentOk = activeAgent === 'all' || card.dataset.agent === activeAgent;
        const kwOk    = activeKw    === 'all' || KW_PATTERNS[activeKw]?.test(card.dataset.title ?? '');
        return mapOk && agentOk && kwOk;
      });
    }

    function sorted(cards: HTMLElement[]) {
      if (sortMode === 'views') {
        return [...cards].sort((a, b) =>
          Number(b.dataset.views ?? 0) - Number(a.dataset.views ?? 0)
        );
      }
      // custom: スコア合計の高い順（data-score はサーバー側で計算済み）
      return [...cards].sort((a, b) =>
        Number(b.dataset.score ?? 0) - Number(a.dataset.score ?? 0)
      );
    }

    function render() {
      const f = sorted(filtered());
      const grid = document.getElementById('clips-grid');
      if (grid) f.forEach(c => grid.appendChild(c)); // 並び替え反映

      allCards().forEach(c => (c.style.display = 'none'));
      const limit = expanded ? f.length : Math.min(INITIAL, f.length);
      f.slice(0, limit).forEach(c => (c.style.display = ''));

      const countEl = document.getElementById('clips-count');
      if (countEl) countEl.textContent = String(f.length);

      const btn = document.getElementById('clips-show-more') as HTMLButtonElement | null;
      if (!btn) return;
      const remaining = f.length - limit;
      if (!expanded && remaining > 0) {
        btn.style.display = 'inline-block';
        btn.textContent = `もっと見る (あと${remaining}件) ▼`;
      } else if (expanded && f.length > INITIAL) {
        btn.style.display = 'inline-block';
        btn.textContent = '折りたたむ ▲';
      } else {
        btn.style.display = 'none';
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      // フィルターボタン
      document.querySelectorAll('.clips-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const el   = btn as HTMLButtonElement;
          const type = el.dataset.filterType  as string;
          const val  = el.dataset.filterValue as string;
          document.querySelectorAll(`.clips-filter-btn[data-filter-type="${type}"]`)
            .forEach(b => b.classList.remove('active'));
          el.classList.add('active');
          if (type === 'map')   activeMap   = val;
          if (type === 'agent') activeAgent = val;
          if (type === 'kw')    activeKw    = val;
          expanded = false;
          render();
        });
      });

      // ソートボタン
      const sortBtns = ['clips-sort-custom', 'clips-sort-views'];
      function setSort(mode: SortMode) {
        sortMode = mode;
        sortBtns.forEach(id => document.getElementById(id)?.classList.remove('active'));
        document.getElementById(mode === 'custom' ? 'clips-sort-custom' : 'clips-sort-views')?.classList.add('active');
        expanded = false;
        render();
      }
      document.getElementById('clips-sort-custom')?.addEventListener('click', () => setSort('custom'));
      document.getElementById('clips-sort-views')?.addEventListener('click',  () => setSort('views'));

      // 列数切り替え（モバイルでは強制1列）
      const isMobile = () => window.innerWidth <= 768;
      document.querySelectorAll('.clips-col-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          if (isMobile()) return;
          const cols = (btn as HTMLElement).dataset.cols ?? '2';
          document.querySelectorAll('.clips-col-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const grid = document.getElementById('clips-grid');
          if (grid) grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        });
      });

      // もっと見るボタン
      document.getElementById('clips-show-more')?.addEventListener('click', () => {
        expanded = !expanded;
        render();
      });

      // サムネイルクリックで動画再生（inline styleでAstroスコープ問題を回避）
      document.querySelectorAll('.clip-thumbnail-wrapper').forEach(wrapper => {
        wrapper.addEventListener('click', () => {
          const el = wrapper as HTMLElement;
          if (el.classList.contains('playing')) return;
          const videoId = el.dataset.videoId;
          el.classList.add('playing');
          const iframe = document.createElement('iframe');
          iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&modestbranding=1&rel=0&fs=1&vq=hd1080`;
          iframe.allow = 'autoplay; encrypted-media; fullscreen';
          iframe.allowFullscreen = true;
          iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;display:block;';
          el.appendChild(iframe);
        });
      });

      render();
    });
  })();
</script>

