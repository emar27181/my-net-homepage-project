  // ===== クリップギャラリー =====
  (function () {
    const INITIAL = 6;
    let activeMap   = 'all';
    let activeAgent = 'all';
    let activeKw    = 'all';
    type SortMode = 'custom' | 'views';
    let sortMode: SortMode = 'custom';
    let expanded    = false;

    // キーワードマッチ（OPのみ単語境界チェック）
    const KW_PATTERNS: Record<string, RegExp> = {
      ult: /ult/i,
    };
    const KW_TAG_FILTERS = ['clutch', 'smooth', 'op', 'guardian', 'ghost', 'bundit', 'vandal', 'bucky', 'spectre', 'classic', 'onemagazine', '6kills'];

    function allCards() {
      return Array.from(document.querySelectorAll('.clip-card')) as HTMLElement[];
    }

    function filtered() {
      return allCards().filter(card => {
        const mapOk   = activeMap   === 'all' || card.dataset.map   === activeMap;
        const agentOk = activeAgent === 'all' || card.dataset.agent === activeAgent;
        const cardTags = (card.dataset.tags ?? '').split(',');
        const kwOk    = activeKw    === 'all'
          || (KW_TAG_FILTERS.includes(activeKw) ? cardTags.includes(activeKw) : KW_PATTERNS[activeKw]?.test(card.dataset.title ?? ''));
        return mapOk && agentOk && kwOk;
      });
    }

    function sorted(cards: HTMLElement[]) {
      if (sortMode === 'views') {
        return [...cards].sort((a, b) =>
          Number(b.dataset.views ?? 0) - Number(a.dataset.views ?? 0)
        );
      }
      // custom: スコア合計の高い順（data-score はサーバー側で計算済み）
      return [...cards].sort((a, b) =>
        Number(b.dataset.score ?? 0) - Number(a.dataset.score ?? 0)
      );
    }

    function render() {
      const f = sorted(filtered());
      const grid = document.getElementById('clips-grid');
      if (grid) f.forEach(c => grid.appendChild(c)); // 並び替え反映

      allCards().forEach(c => (c.style.display = 'none'));
      const limit = expanded ? f.length : Math.min(INITIAL, f.length);
      f.slice(0, limit).forEach(c => (c.style.display = ''));

      const countEl = document.getElementById('clips-count');
      if (countEl) countEl.textContent = String(f.length);

      const btn = document.getElementById('clips-show-more') as HTMLButtonElement | null;
      if (!btn) return;
      const remaining = f.length - limit;
      if (!expanded && remaining > 0) {
        btn.style.display = 'inline-block';
        btn.textContent = `もっと見る (あと${remaining}件) ▼`;
      } else if (expanded && f.length > INITIAL) {
        btn.style.display = 'inline-block';
        btn.textContent = '折りたたむ ▲';
      } else {
        btn.style.display = 'none';
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      // フィルターボタン
      document.querySelectorAll('.clips-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const el   = btn as HTMLButtonElement;
          const type = el.dataset.filterType  as string;
          const val  = el.dataset.filterValue as string;
          document.querySelectorAll(`.clips-filter-btn[data-filter-type="${type}"]`)
            .forEach(b => b.classList.remove('active'));
          el.classList.add('active');
          if (type === 'map')   activeMap   = val;
          if (type === 'agent') activeAgent = val;
          if (type === 'kw')    activeKw    = val;
          expanded = false;
          render();
        });
      });

      // バッジクリックでフィルター（map / agent / kw）
      function activateFilter(type: string, val: string) {
        if (type === 'map')   { activeMap   = val; }
        if (type === 'agent') { activeAgent = val; }
        if (type === 'kw')    { activeKw    = val; }
        document.querySelectorAll(`.clips-filter-btn[data-filter-type="${type}"]`)
          .forEach(b => b.classList.remove('active'));
        document.querySelector(`.clips-filter-btn[data-filter-type="${type}"][data-filter-value="${val}"]`)
          ?.classList.add('active');
        expanded = false;
        render();
        // フィルターエリアにスクロール
        document.querySelector('.filter-row')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      document.querySelectorAll('.clickable-badge').forEach(badge => {
        badge.addEventListener('click', (e) => {
          e.stopPropagation();
          const el   = badge as HTMLElement;
          const type = el.dataset.filterType;
          const val  = el.dataset.filterValue;
          if (type && val) activateFilter(type, val);
        });
      });

      // ソートボタン
      const sortBtns = ['clips-sort-custom', 'clips-sort-views'];
      function setSort(mode: SortMode) {
        sortMode = mode;
        sortBtns.forEach(id => document.getElementById(id)?.classList.remove('active'));
        document.getElementById(mode === 'custom' ? 'clips-sort-custom' : 'clips-sort-views')?.classList.add('active');
        expanded = false;
        render();
      }
      document.getElementById('clips-sort-custom')?.addEventListener('click', () => setSort('custom'));
      document.getElementById('clips-sort-views')?.addEventListener('click',  () => setSort('views'));

      // 列数切り替え（モバイルでは強制1列）
      const isMobile = () => window.innerWidth <= 768;
      document.querySelectorAll('.clips-col-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          if (isMobile()) return;
          const cols = (btn as HTMLElement).dataset.cols ?? '2';
          document.querySelectorAll('.clips-col-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const grid = document.getElementById('clips-grid');
          if (grid) grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        });
      });

      // もっと見るボタン
      document.getElementById('clips-show-more')?.addEventListener('click', () => {
        expanded = !expanded;
        render();
      });

      // ========== ショートモード ==========
      // ========== SHORT モード ==========
      const shortContainer = document.getElementById('short-scroll-container') as HTMLElement;
      const shortTrack     = document.getElementById('short-cards-track') as HTMLElement;
      const shortHud       = document.getElementById('short-hud') as HTMLElement;
      const shortCloseBtn  = document.getElementById('short-close-btn') as HTMLButtonElement;
      const shortCounter   = document.getElementById('short-counter') as HTMLElement;
      const viewGridBtn    = document.getElementById('clips-view-grid') as HTMLButtonElement;
      const viewShortBtn   = document.getElementById('clips-view-short') as HTMLButtonElement;

      let shortIndex = 0;
      let shortTotal = 0;

      function playShortAt(idx: number) {
        const card = shortTrack.children[idx] as HTMLElement | undefined;
        if (!card) return;
        const videoId = card.dataset.videoId ?? '';
        if (!videoId || card.querySelector('iframe')) return;
        card.querySelector('.short-play-overlay')?.classList.add('hidden');
        const wrap = card.querySelector<HTMLElement>('.short-video-wrap')!;
        // iframe で直接再生（YT.Player経由だとユーザージェスチャー外になり autoplay がブロックされる）
        const iframe = document.createElement('iframe');
        iframe.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('frameborder', '0');
        iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&playsinline=1&modestbranding=1&rel=0&cc_load_policy=0&vq=hd1080&hd=1`;
        wrap.appendChild(iframe);
      }

      function stopShortAt(idx: number) {
        const card = shortTrack.children[idx] as HTMLElement | undefined;
        if (!card) return;
        card.querySelector('iframe')?.remove();
        card.querySelector('.short-play-overlay')?.classList.remove('hidden');
      }

      // iOS Safariで100vhとwindow.innerHeightがズレる問題を回避するため
      // ビューポート高さをwindow.innerHeightで統一管理
      let shortVh = window.innerHeight;

      function updateShortVh() {
        shortVh = window.innerHeight;
        shortContainer.style.height = shortVh + 'px';
        shortTrack.querySelectorAll<HTMLElement>('.short-card').forEach(c => {
          c.style.height = shortVh + 'px';
        });
      }

      function setTrackY(offset: number) {
        shortTrack.style.transform = `translateY(${offset}px)`;
      }

      function goToShort(idx: number, animate = true) {
        const prev = shortIndex;
        shortIndex = Math.max(0, Math.min(idx, shortTotal - 1));
        if (prev !== shortIndex) stopShortAt(prev);
        if (animate) {
          shortTrack.classList.remove('no-transition');
        } else {
          shortTrack.classList.add('no-transition');
        }
        setTrackY(-shortIndex * shortVh);
        shortCounter.textContent = `${shortIndex + 1} / ${shortTotal}`;
        // ユーザージェスチャーのコンテキスト内で同期的に iframe を生成する。
        // setTimeout を挟むと autoplay がブロックされるため、スライド中でも即座に呼ぶ。
        // （カードが画面外で再生開始 → スライド完了時には既に再生中になる）
        playShortAt(shortIndex);
      }

      function buildShortCards() {
        const visibleCards = allCards().filter(c => c.style.display !== 'none');
        shortTrack.innerHTML = '';
        shortIndex = 0;
        shortTotal = visibleCards.length;
        shortCounter.textContent = `1 / ${shortTotal}`;

        visibleCards.forEach((card, idx) => {
          const videoId  = card.querySelector<HTMLElement>('.clip-thumbnail-wrapper')?.dataset.videoId ?? '';
          const title    = card.querySelector('.clip-video-title')?.textContent ?? '';
          const metaHTML = card.querySelector('.clip-meta')?.innerHTML ?? '';
          const thumbUrl = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;

          const sc = document.createElement('div');
          sc.className = 'short-card';
          sc.dataset.index = String(idx);
          sc.dataset.videoId = videoId;
          sc.innerHTML = `
            <div class="short-bg" style="background-image:url('${thumbUrl}')"></div>
            <div class="short-video-wrap">
              <img class="short-thumb" src="${thumbUrl}" alt="${title}" loading="lazy" />
              <div class="short-play-overlay"><span class="short-play-icon">▶</span></div>
            </div>
            <div class="short-info">
              <div class="short-title">${title}</div>
              <div class="short-badges">${metaHTML}</div>
            </div>`;

          // タップで手動再生
          sc.querySelector('.short-video-wrap')?.addEventListener('click', () => {
            playShortAt(idx);
          });

          shortTrack.appendChild(sc);
        });
      }

      // ========== タッチ：指追従スライド ==========
      let touchY0 = 0;
      let touchDragging = false;
      shortContainer.addEventListener('touchstart', (e) => {
        touchY0 = e.touches[0].clientY;
        touchDragging = true;
        // ドラッグ中はアニメーション無効化（touchend で戻す）
        shortTrack.classList.add('no-transition');
      }, { passive: true });
      shortContainer.addEventListener('touchmove', (e) => {
        if (!touchDragging) return;
        const dy = e.touches[0].clientY - touchY0;
        const base = -shortIndex * shortVh;
        const resist = (dy > 0 && shortIndex === 0) || (dy < 0 && shortIndex === shortTotal - 1);
        setTrackY(base + (resist ? dy * 0.25 : dy));
      }, { passive: true });
      shortContainer.addEventListener('touchend', (e) => {
        if (!touchDragging) return;
        touchDragging = false;
        // アニメーション復活
        shortTrack.classList.remove('no-transition');
        const dy = touchY0 - e.changedTouches[0].clientY;
        if (dy > 40) goToShort(shortIndex + 1);
        else if (dy < -40) goToShort(shortIndex - 1);
        else goToShort(shortIndex);
      }, { passive: true });

      // マウスホイール (PC)
      let wheelLocked = false;
      shortContainer.addEventListener('wheel', (e) => {
        e.preventDefault();
        if (wheelLocked) return;
        wheelLocked = true;
        if (e.deltaY > 0) goToShort(shortIndex + 1);
        else goToShort(shortIndex - 1);
        setTimeout(() => { wheelLocked = false; }, 600);
      }, { passive: false });

      // キーボード
      document.addEventListener('keydown', (e) => {
        if (!shortHud.classList.contains('active')) return;
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') goToShort(shortIndex + 1);
        if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  goToShort(shortIndex - 1);
        if (e.key === 'Escape') closeShortMode();
      });

      window.addEventListener('resize', () => {
        if (shortContainer.classList.contains('active')) {
          updateShortVh();
          setTrackY(-shortIndex * shortVh);
        }
      });

      function openShortMode() {
        buildShortCards();
        updateShortVh();
        goToShort(0, false);
        shortContainer.classList.add('active');
        shortHud.classList.add('active');
        document.body.style.overflow = 'hidden';
        viewGridBtn.classList.remove('active');
        viewShortBtn.classList.add('active');
      }

      function closeShortMode() {
        shortContainer.classList.remove('active');
        shortHud.classList.remove('active');
        document.body.style.overflow = '';
        shortTrack.innerHTML = '';
        viewGridBtn.classList.add('active');
        viewShortBtn.classList.remove('active');
      }

      viewShortBtn?.addEventListener('click', openShortMode);
      viewGridBtn?.addEventListener('click', closeShortMode);
      shortCloseBtn?.addEventListener('click', closeShortMode);

      // YouTube プレイリストリンク: モバイルはアプリ起動、PCは新タブ
      const ytLink = document.getElementById('clips-yt-link');
      ytLink?.addEventListener('click', (e) => {
        e.preventDefault();
        // href 属性から URL を取得（Astro SSR で正しいURLが埋め込まれている）
        const webUrl = (ytLink as HTMLAnchorElement).href;
        const appUrl = webUrl.replace('https://', 'youtube://');
        const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
        if (isMobile) {
          const t = setTimeout(() => { window.location.href = webUrl; }, 2000);
          window.location.href = appUrl;
          const cancel = () => { clearTimeout(t); document.removeEventListener('visibilitychange', cancel); };
          document.addEventListener('visibilitychange', cancel);
        } else {
          window.open(webUrl, '_blank', 'noopener');
        }
      });

      // クリップギャラリー: YouTube API経由で画質を最高に設定
      function applyMaxQualityToClipPlayer(player: any) {
        try {
          const levels: string[] = player.getAvailableQualityLevels?.() || [];
          const best = ['hd1080', 'hd720', 'large'].find(q => levels.includes(q)) || 'hd1080';
          player.setPlaybackQuality(best);
          if (typeof player.setPlaybackQualityRange === 'function') {
            player.setPlaybackQualityRange(best, 'highres');
          }
          [500, 2000, 4000].forEach(d => setTimeout(() => { try { player.setPlaybackQuality(best); } catch(_){} }, d));
        } catch (_) {}
      }

      function bindClipQuality(iframe: HTMLIFrameElement) {
        const tryBind = () => {
          const YT = (window as any).YT;
          if (YT?.Player) {
            try {
              new YT.Player(iframe.id, {
                events: {
                  onReady(e: any) { applyMaxQualityToClipPlayer(e.target); },
                  onStateChange(e: any) {
                    if (e.data === 1 || e.data === 3) applyMaxQualityToClipPlayer(e.target);
                  },
                  onPlaybackQualityChange(e: any) {
                    const cur = e.target.getPlaybackQuality();
                    if (cur !== 'hd1080' && cur !== 'highres') applyMaxQualityToClipPlayer(e.target);
                  }
                }
              });
            } catch (_) {}
          } else {
            setTimeout(tryBind, 500);
          }
        };
        setTimeout(tryBind, 300);
      }

      // サムネイルクリックで動画再生（inline styleでAstroスコープ問題を回避）
      document.querySelectorAll('.clip-thumbnail-wrapper').forEach(wrapper => {
        wrapper.addEventListener('click', () => {
          const el = wrapper as HTMLElement;
          if (el.classList.contains('playing')) return;
          const videoId = el.dataset.videoId;
          el.classList.add('playing');
          const iframe = document.createElement('iframe');
          iframe.id = `clip-player-${videoId}-${Date.now()}`;
          iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&modestbranding=1&rel=0&fs=1&enablejsapi=1&playsinline=1&vq=hd1080&hd=1`;
          iframe.allow = 'autoplay; encrypted-media; fullscreen';
          iframe.allowFullscreen = true;
          iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;display:block;';
          el.appendChild(iframe);
          bindClipQuality(iframe);
        });
      });

      render();
    });
  })();
</script>
