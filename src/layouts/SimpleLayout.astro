---
import { NAV_CONFIG } from '../config/themeConfig';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "nodoamen のポートフォリオサイト。VALORANT(ヴァロラント)の統計データ、ゲームプレイ動画、デバイス情報などを公開しています。" } = Astro.props;
const pageTitle = `${title} | nodoamen | Valorant Stats`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon_omencat_transparent.png" />
    <title>{pageTitle}</title>
    <meta
      name="keywords"
      content="nodoamen, valorant, ヴァロラント, portfolio, stats, portfolio, valorant stats, valorant tracker, valorant profile"
    />
    <meta name="author" content="nodoamen" />
    <meta
      name="google-site-verification"
      content="uyjBT9z6vOnpxn6lM6YnxbI6R4jLSDIAboC8zo1slhM"
    />
  </head>
  <body
    style="margin: 0; padding: 0; background-color: #0f0f27; color: white; font-family: 'Press Start 2P', monospace; image-rendering: pixelated;"
    class="mobile-body"
  >
    <!-- ナビゲーションバー -->
    <nav id="page-nav">
      <div class="nav-links">
        {NAV_CONFIG.links.map(link => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </div>
      <button id="settings-toggle" class="settings-toggle-btn nav-link" aria-label="設定">{NAV_CONFIG.settingsLabel}</button>
    </nav>

    <!-- 設定パネル -->
    <div id="settings-panel" class="settings-panel" aria-hidden="true">
      <div class="settings-row">
        <span class="settings-label">COLOR HUE</span>
        <input type="range" id="hue-slider" min="0" max="360" value="225" step="1" class="hue-slider">
        <span id="hue-value-display" class="hue-value-display">225</span>
      </div>
      <div class="hue-presets">
        <button class="hue-preset-btn" data-hue="225" style="--pc: hsl(225,100%,65%)">Blue</button>
        <button class="hue-preset-btn" data-hue="180" style="--pc: hsl(180,100%,65%)">Cyan</button>
        <button class="hue-preset-btn" data-hue="270" style="--pc: hsl(270,100%,65%)">Purple</button>
        <button class="hue-preset-btn" data-hue="300" style="--pc: hsl(300,100%,65%)">Pink</button>
        <button class="hue-preset-btn" data-hue="120" style="--pc: hsl(120,100%,65%)">Green</button>
        <button class="hue-preset-btn" data-hue="30"  style="--pc: hsl(30,100%,65%)">Orange</button>
      </div>
    </div>

    <slot />

    <!-- ドットフォントのGoogle Fonts読み込み -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=DotGothic16&family=BIZ+UDPGothic:wght@400;700&family=VT323&display=swap"
      rel="stylesheet"
    />

    <style>
      /* CSS変数定義 */
      :root {
        --font-pixel: "Press Start 2P", cursive;
        --font-mono: "VT323", monospace;
        --font-pixel-jp: "DotGothic16", "BIZ UDPGothic", "Press Start 2P", monospace;
        --font-main-jp: "DotGothic16", "BIZ UDPGothic", sans-serif;

        /* テーマカラー — hueを変えるだけで全色が追従 */
        --theme-hue: 225;
        --col-primary:    hsl(var(--theme-hue), 100%, 65%);
        --col-primary-a7: hsla(var(--theme-hue), 100%, 65%, 0.07);
        --col-primary-a10: hsla(var(--theme-hue), 100%, 65%, 0.1);
        --col-primary-a12: hsla(var(--theme-hue), 100%, 65%, 0.12);
        --col-primary-a20: hsla(var(--theme-hue), 100%, 65%, 0.2);
        --col-primary-a25: hsla(var(--theme-hue), 100%, 65%, 0.25);
        --col-primary-a28: hsla(var(--theme-hue), 100%, 65%, 0.28);
        --col-primary-a30: hsla(var(--theme-hue), 100%, 65%, 0.3);
        --col-primary-a35: hsla(var(--theme-hue), 100%, 65%, 0.35);
        --col-primary-a40: hsla(var(--theme-hue), 100%, 65%, 0.4);
        --col-primary-a45: hsla(var(--theme-hue), 100%, 65%, 0.45);
        --col-primary-a50: hsla(var(--theme-hue), 100%, 65%, 0.5);
        --col-primary-a60: hsla(var(--theme-hue), 100%, 65%, 0.6);
        --col-primary-a70: hsla(var(--theme-hue), 100%, 65%, 0.7);

        /* フォントサイズ — デスクトップ基準 */
        /* body/subtitle: 14px 以上、small/footer: 12px 以上を維持 */
        --fs-title:    20px;
        --fs-section:  15px;
        --fs-subtitle: 14px;
        --fs-body:     14px;
        --fs-small:    12px;
        --fs-footer:   12px;
      }

      /* タブレット〜スマホ縦画面 */
      @media (max-width: 768px) {
        :root {
          --fs-title:    16px;
          --fs-section:  13px;
          --fs-subtitle: 13px;
          --fs-body:     13px;
          --fs-small:    11px;
          --fs-footer:   11px;
        }
      }

      /* 小画面スマホ */
      @media (max-width: 480px) {
        :root {
          --fs-title:    15px;
          --fs-section:  13px;
          --fs-subtitle: 13px;
          --fs-body:     13px;
          --fs-small:    10px;
          --fs-footer:   10px;
        }
      }

      /* スマホ横画面: 幅がタブレット相当のため同サイズを適用 */
      @media (orientation: landscape) and (max-height: 600px) {
        :root {
          --fs-title:    16px;
          --fs-section:  13px;
          --fs-subtitle: 13px;
          --fs-body:     13px;
          --fs-small:    11px;
          --fs-footer:   11px;
        }
      }

      /* 全体的なドットフォント適用 */
      * {
        font-family: var(--font-pixel-jp) !important;
        image-rendering: pixelated !important;
        text-rendering: optimizeSpeed !important;
      }

      /* 英数字はPress Start 2P、日本語はDotGothic16 */
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-pixel-jp) !important;
        text-shadow: 1px 1px 0px #000000 !important;
      }

      p,
      span,
      div {
        font-family: var(--font-pixel-jp) !important;
        text-shadow: 1px 1px 0px #000000 !important;
      }

      /* ピクセル感を強調 */
      body {
        -webkit-font-smoothing: none !important;
        -moz-osx-font-smoothing: unset !important;
        font-smooth: never !important;
        font-family: var(--font-pixel-jp) !important;
      }

      /* 動画グリッドのデフォルトスタイル（デスクトップ） */
      .main-container .video-grid,
      .video-grid {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr) !important;
        gap: 20px !important;
        width: 100% !important;
      }

      /* タブレット表示 */
      @media screen and (max-width: 768px) {
        .main-container .video-grid,
        .video-grid {
          grid-template-columns: 1fr !important;
          gap: 20px !important;
        }
      }

      /* スマホ表示 */
      @media screen and (max-width: 480px) {
        .main-container .video-grid,
        .video-grid {
          grid-template-columns: 1fr !important;
          gap: 0 !important;
        }
        
        .main-container {
          padding: 0 !important;
          border-width: 0 !important;
          margin: 0 !important;
          border-radius: 0 !important;
          background: transparent !important;
          box-shadow: none !important;
        }
        
        .mobile-main {
          max-width: 100% !important;
          width: 100vw !important;
          min-height: 100vh !important;
        }
        
        /* スマホでのタイトルセクション最小化 */
        @media screen and (max-width: 480px) {
          .mobile-body {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
          }
          
          /* 全てのpaddingとmarginを0pxに */
          .main-container {
            padding: 0px !important;
            margin: 0px !important;
            max-width: 100vw !important;
            border: none !important;
            border-radius: 0px !important;
          }
          
          /* 各セクションのpaddingとmarginを0px */
          .main-container > div {
            padding: 0px !important;
            margin: 0px !important;
            margin-bottom: 2px !important;
            border-radius: 0px !important;
          }
          
          /* My Works内部の全ての余白を0px */
          .main-container > div > div > div[style*="padding: 15px"] {
            padding: 0px !important;
            margin: 0px !important;
          }
          
          /* 全てのdivの余白を強制的に削除 */
          .main-container * {
            margin-left: 0px !important;
            margin-right: 0px !important;
            padding-left: 0px !important;
            padding-right: 0px !important;
          }
          
          .title-section {
            margin-bottom: 2px !important;
            padding: 1px !important;
          }

          .video-section {
            padding: 0px !important;
            margin: 0 !important;
            border: none !important;
            background: transparent !important;
          }
        }
      }
      /* ========== ナビゲーションバー ========== */
      #page-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 9000;
        height: 40px;
        background: rgba(6, 6, 15, 0.95);
        border-bottom: 2px solid var(--col-primary);
        box-shadow: 0 0 12px var(--col-primary-a30);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px;
        font-family: var(--font-pixel) !important;
      }
      .nav-links {
        display: flex;
        gap: 20px;
      }
      .nav-link {
        font-family: var(--font-pixel) !important;
        font-size: 10px;
        color: var(--col-primary-a70);
        text-decoration: none;
        text-shadow: 0 0 6px var(--col-primary-a50), 1px 1px 0 #000;
        image-rendering: pixelated;
        transition: color 0.2s, text-shadow 0.2s;
        white-space: nowrap;
      }
      .nav-link:hover {
        color: var(--col-primary);
        text-shadow: 0 0 10px var(--col-primary), 1px 1px 0 #000;
      }
      .settings-toggle-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        line-height: 1;
      }

      /* ========== 設定パネル ========== */
      .settings-panel {
        position: fixed;
        top: 42px; right: 8px;
        z-index: 8999;
        background: rgba(6, 6, 15, 0.97);
        border: 2px solid var(--col-primary);
        box-shadow: 0 0 16px var(--col-primary-a30);
        border-radius: 6px;
        padding: 14px 16px;
        min-width: 240px;
        font-family: var(--font-pixel-jp) !important;
        font-size: 12px;
        display: none;
      }
      .settings-panel.open { display: block; }

      .settings-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
      }
      .settings-label {
        font-family: var(--font-pixel) !important;
        font-size: 9px;
        color: var(--col-primary);
        text-shadow: 0 0 6px var(--col-primary-a50), 1px 1px 0 #000;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .hue-slider {
        flex: 1;
        height: 4px;
        cursor: pointer;
        accent-color: var(--col-primary);
      }
      .hue-value-display {
        font-family: var(--font-pixel) !important;
        font-size: 9px;
        color: #aabbdd;
        text-shadow: 1px 1px 0 #000;
        min-width: 28px;
        text-align: right;
      }
      .hue-presets {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      .hue-preset-btn {
        font-family: var(--font-pixel) !important;
        font-size: 8px;
        padding: 3px 8px;
        background: color-mix(in srgb, var(--pc) 10%, transparent);
        border: 1px solid color-mix(in srgb, var(--pc) 50%, transparent);
        color: var(--pc);
        border-radius: 3px;
        cursor: pointer;
        text-shadow: 1px 1px 0 #000;
        transition: background 0.15s;
        image-rendering: pixelated;
      }
      .hue-preset-btn:hover {
        background: color-mix(in srgb, var(--pc) 25%, transparent);
      }

      /* ナビ分のpadding */
      body > *:not(#page-nav):not(.settings-panel) {
        padding-top: 0;
      }

      @media (max-width: 480px) {
        .nav-links { gap: 10px; }
        .nav-link { font-size: 8px; }
        .settings-panel { right: 4px; min-width: 200px; }
      }
    </style>

    <script>
      (function () {
        const HUE_KEY = 'theme-hue';
        const root = document.documentElement;

        function applyHue(hue) {
          root.style.setProperty('--theme-hue', String(hue));
          const slider = document.getElementById('hue-slider');
          const display = document.getElementById('hue-value-display');
          if (slider) slider.value = hue;
          if (display) display.textContent = hue;
        }

        // 保存済みhueを復元
        const saved = localStorage.getItem(HUE_KEY);
        if (saved) applyHue(Number(saved));

        document.addEventListener('DOMContentLoaded', function () {
          const toggleBtn = document.getElementById('settings-toggle');
          const panel = document.getElementById('settings-panel');
          const slider = document.getElementById('hue-slider');
          const display = document.getElementById('hue-value-display');

          // 現在のhueをスライダーに反映
          const currentHue = getComputedStyle(root).getPropertyValue('--theme-hue').trim() || '225';
          applyHue(Number(currentHue));

          // パネル開閉
          toggleBtn?.addEventListener('click', function () {
            panel?.classList.toggle('open');
            toggleBtn.classList.toggle('active');
          });

          // パネル外クリックで閉じる
          document.addEventListener('click', function (e) {
            if (!panel?.contains(e.target) && e.target !== toggleBtn) {
              panel?.classList.remove('open');
              toggleBtn?.classList.remove('active');
            }
          });

          // スライダー操作
          slider?.addEventListener('input', function () {
            const hue = Number(this.value);
            applyHue(hue);
            localStorage.setItem(HUE_KEY, String(hue));
          });

          // プリセットボタン
          document.querySelectorAll('.hue-preset-btn').forEach(btn => {
            btn.addEventListener('click', function () {
              const hue = Number(this.dataset.hue);
              applyHue(hue);
              localStorage.setItem(HUE_KEY, String(hue));
            });
          });
        });
      })();
    </script>
  </body>
</html>
